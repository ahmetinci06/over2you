---
interface Props {
  title?: string;
  transparentHeader?: boolean;
  description?: string;
}
const { title = 'Over2You | OFFICIAL WEBSITE', transparentHeader = false, description = 'Over2You — Premium streetwear and essentials.' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---
<!doctype html>
<html lang="tr" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={`${base}img/hero-desktop-1.jpg`} />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="stylesheet" href={`${base}css/style.css`} />
  <script is:inline define:vars={{base}}>window.O2Y_BASE = base;</script>
</head>
<body class="color-scheme color-scheme--scheme-1">
  <header class={`header ${transparentHeader ? 'header--transparent' : ''}`} id="header">
    <div class="header-inner">
      <div class="header-primary-nav">
        <button class="menu-toggle" id="menuToggle" aria-label="Menu"><span></span><span></span><span></span></button>
        <a href={base} class="nav-link" data-i18n="nav.newIn">YENİ GELENLER</a>
        <div class="nav-dropdown" id="desktopShopNav"><a href="#" class="nav-link nav-dropdown-trigger" data-i18n="nav.shopAll">TÜM ÜRÜNLER</a></div>
        <a href={`${base}shop`} class="nav-link">OVER2YOU+</a>
        <a href="#" class="nav-link" data-i18n="nav.collections">KOLEKSİYONLAR</a>
        <a href={`${base}shop?cat=women`} class="nav-link" data-i18n="nav.women">KADIN</a>
        <a href="#" class="nav-link" data-i18n="nav.sports">SPOR</a>
        <a href={`${base}about`} class="nav-link" data-i18n="nav.brand">HAKKIMIZDA</a>
      </div>
      <a href={base} class="header-logo"><span class="logo-text">OVER2YOU</span></a>
      <div class="header-secondary-nav">
        <a href="#" class="nav-link" style="opacity:0;pointer-events:none;">.</a>
        <button id="langSwitch" style="cursor:pointer;background:none;border:1px solid rgba(255,255,255,0.3);color:#fff;padding:4px 10px;font-size:11px;font-weight:700;letter-spacing:1px;margin-right:8px;">EN</button>
        <button class="icon-btn search-btn" id="searchBtn" aria-label="Search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </button>
        <button class="icon-btn cart-btn" id="cartBtn" aria-label="Cart">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <span class="cart-count" id="cartCount">0</span>
        </button>
      </div>
    </div>
  </header>

  <div class="mobile-nav-overlay" id="mobileNavOverlay"></div>
  <nav class="mobile-nav" id="mobileNav">
    <div class="mobile-nav-header">
      <button class="menu-close" id="menuCloseBtn" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"></path></svg>
      </button>
    </div>
    <div class="mobile-nav-content">
      <ul class="nav-list main-nav-list" id="mainNavList">
        <li><a href={base} class="mobile-nav-link" data-i18n="nav.newIn">YENİ GELENLER</a></li>
        <li><a href="#" class="mobile-nav-link has-submenu" data-target="shopMenu">SHOP ALL <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"></path></svg></a></li>
        <li><a href="#" class="mobile-nav-link has-submenu">OVER2YOU+ <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"></path></svg></a></li>
        <li>
          <div class="nav-widget">
            <span class="nav-widget-title" data-i18n="cat.colors">RENKLER:</span>
            <div class="color-swatches">
              {['black','pink','dark','brown','grey','white','red','blue'].map(c => (
                <a href={`${base}shop?color=${c}`} class="color-swatch" style={`background:${
                  {black:'#2a2a2a',pink:'#e8b5ce',dark:'#111',brown:'#5c4033',grey:'#808080',white:'#f5f5f5',red:'#c94c4c',blue:'#6495ed'}[c]
                }`} title={c.charAt(0).toUpperCase()+c.slice(1)}></a>
              ))}
            </div>
          </div>
          <div class="nav-widget">
            <span class="nav-widget-title" data-i18n="cat.categories">KATEGORİLER:</span>
            <div class="category-thumbs">
              <a href={`${base}shop`} class="cat-thumb"><div class="cat-img-box"><span style="font-weight:900;font-size:10px;">O2Y+</span></div><span data-i18n="nav.shopAll">TÜM ÜRÜNLER</span></a>
              <a href={`${base}shop?cat=hoodies`} class="cat-thumb"><div class="cat-img-box"><img src={`${base}img/col-hoodies.jpg`} alt="Hoodies" /></div><span data-i18n="cat.hoodies">SWEATSHIRT</span></a>
              <a href={`${base}shop?cat=sweatpants`} class="cat-thumb"><div class="cat-img-box"><img src={`${base}img/col-sweatpants.jpg`} alt="Sweatpants" /></div><span data-i18n="cat.sweatpants">EŞOFMAN</span></a>
              <a href={`${base}shop?cat=crewnecks`} class="cat-thumb"><div class="cat-img-box"><img src={`${base}img/col-crewnecks.jpg`} alt="Crewnecks" /></div><span data-i18n="cat.crewnecks">CREWNECK</span></a>
            </div>
          </div>
        </li>
        <li><a href={`${base}shop?cat=women`} class="mobile-nav-link" data-i18n="nav.women">KADIN</a></li>
        <li><a href="#" class="mobile-nav-link" data-i18n="nav.sports">SPOR</a></li>
        <li><a href={`${base}about`} class="mobile-nav-link has-submenu">BRAND <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"></path></svg></a></li>
      </ul>
      <div class="submenu-container" id="shopMenu">
        <button class="submenu-back" aria-label="Back"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"></path></svg> BACK</button>
        <ul class="nav-list">
          <li><a href={`${base}shop`} class="mobile-nav-link" data-i18n="nav.shopAll">TÜM ÜRÜNLER</a></li>
          <li><a href={`${base}shop?cat=hoodies`} class="mobile-nav-link" data-i18n="cat.hoodies">SWEATSHIRT</a></li>
          <li><a href={`${base}shop?cat=sweatpants`} class="mobile-nav-link" data-i18n="cat.sweatpants">EŞOFMAN</a></li>
          <li><a href={`${base}shop?cat=crewnecks`} class="mobile-nav-link" data-i18n="cat.crewnecks">CREWNECK</a></li>
          <li><a href={`${base}shop?cat=tshirts`} class="mobile-nav-link" data-i18n="cat.tshirts">TİŞÖRT</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <slot />

  <!-- Search Modal -->
  <div class="search-modal" id="searchModal">
    <div class="search-modal-inner">
      <input type="text" placeholder="Ara..." data-i18n="search.placeholder" id="searchInput" autocomplete="off" />
      <button id="searchClose" aria-label="Close"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    </div>
    <div id="searchResults"></div>
  </div>

  <!-- Cart Drawer -->
  <div class="cart-overlay" id="cartOverlay"></div>
  <div class="cart-drawer" id="cartDrawer">
    <div class="cart-drawer-header"><h3 data-i18n="cart.title">SEPET</h3><button class="cart-drawer-close" id="cartClose"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
    <div class="cart-drawer-body" id="cartBody"><p class="cart-empty-msg" data-i18n="cart.empty">Sepetiniz boş</p></div>
    <div class="cart-drawer-footer" id="cartFooter" style="display:none">
      <div class="cart-total-row"><span data-i18n="cart.total">Toplam</span><span id="cartTotal">€0.00</span></div>
      <button class="btn-checkout" data-i18n="cart.checkout">ÖDEMEYE GEÇ</button>
    </div>
  </div>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-grid">
      <div class="footer-col"><h4 data-i18n="footer.support">DESTEK</h4><p data-i18n="footer.supportText">SİPARİŞ SORULARI İÇİN BİZE ULAŞIN</p><a href="mailto:SUPPORT@OVER2YOU.COM">SUPPORT@OVER2YOU.COM</a><p data-i18n="footer.weekdays">(PAZARTESİ-CUMA)</p><br/><a href="#" data-i18n="footer.whatsapp">OVER2YOU WHATSAPP KANALINA KATILIN</a><p data-i18n="footer.earlyAccess">ERKEN ERİŞİM, İNDİRİMLER & FIRSATLAR</p><a href="#" data-i18n="footer.joinNow">HEMEN KATILIN →</a></div>
      <div class="footer-col"><h4 data-i18n="footer.service">Hizmet</h4><a href="#" data-i18n="footer.support">DESTEK</a><a href="#" data-i18n="footer.returns">İade</a><a href="#" data-i18n="footer.shippingLink">Kargo</a><a href="#" data-i18n="footer.orderTracking">Sipariş Takibi</a></div>
      <div class="footer-col"><h4 data-i18n="footer.legal">Yasal</h4><a href="#" data-i18n="footer.imprint">Künye</a><a href="#" data-i18n="footer.privacy">Gizlilik Politikası</a><a href="#" data-i18n="footer.terms">Kullanım Koşulları</a><a href="#" data-i18n="footer.refund">İade Politikası</a></div>
      <div class="footer-col"><h4 data-i18n="footer.more">Daha Fazla</h4><a href="#" data-i18n="footer.socials">SOSYAL MEDYA</a>
        <div class="social-links" style="margin-top:0.75rem">
          <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
          <a href="#" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.53v-3.4a4.85 4.85 0 01-.81-.05l-.38-.06z"/></svg></a>
          <a href="#" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
        </div>
        <br/><p data-i18n="footer.securePayments">GÜVENLİ ÖDEME</p>
      </div>
    </div>
    <div class="footer-bottom"><p>© 2026 - Over2You. Tüm hakları saklıdır.</p></div>
  </footer>

  <script is:inline src={`${base}js/i18n.js?v=3`}></script>
  <script is:inline src={`${base}js/app.js?v=4`}></script>
  <script is:inline src={`${base}js/carousel-3d.js?v=2`}></script>
</body>
</html>
