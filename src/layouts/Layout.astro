---
import Footer from '../components/Footer.astro';
interface Props {
  title?: string;
  transparentHeader?: boolean;
  description?: string;
}
const { title = 'Over2You | OFFICIAL WEBSITE', transparentHeader = false, description = 'Over2You — Premium streetwear and essentials.' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---
<!doctype html>
<html lang="tr" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={`${base}img/hero-desktop-1.jpg`} />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <link rel="stylesheet" href={`${base}css/style.css`} />
  <script is:inline define:vars={{base}}>window.O2Y_BASE = base;</script>
  <style>
    /* lang switch — pill, dark text + dark border so it reads on the
       solid-white header used by all pages except the home (which is
       transparentHeader). On the home hero, dark text on dark photo
       reads at the same level as the rest of the header nav-links. */
    .lang-switch {
      cursor: pointer;
      background: none;
      border: 1px solid rgb(var(--text-color) / 0.3);
      color: rgb(var(--text-color));
      padding: 4px 10px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1px;
      margin-right: 8px;
      border-radius: 4px;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .lang-switch:hover {
      background: rgb(var(--text-color));
      color: rgb(var(--background));
      border-color: rgb(var(--text-color));
    }
    /* On home (transparentHeader=true), the header text is white so the
       hamburger lines show. Match the lang switch to that. */
    .header.header--transparent .lang-switch {
      color: #fff;
      border-color: rgba(255, 255, 255, 0.5);
    }
    .header.header--transparent .lang-switch:hover {
      background: #fff;
      color: #000;
      border-color: #fff;
    }
    /* Hide in header on mobile — moved to the mobile drawer footer */
    @media (max-width: 999px) {
      .lang-switch { display: none; }
    }

    /* Mobile drawer language toggle. Triggers #langSwitch via onclick. */
    .mobile-nav-footer {
      margin-top: auto;
      padding: 1.5rem var(--container-gutter);
      border-top: 1px solid rgba(0, 0, 0, 0.08);
    }
    .mobile-lang-toggle {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 0.6rem;
      width: 100%;
      background: none;
      border: 0;
      padding: 0.5rem 0;
      font: var(--heading-font-style) 600 13px/1 var(--heading-font-family);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: rgb(var(--text-color) / 0.4);
      cursor: pointer;
      text-align: left;
    }
    .mobile-lang-toggle .mobile-lang-tr,
    .mobile-lang-toggle .mobile-lang-en {
      transition: color 0.15s, font-weight 0.15s;
    }
    html[lang="tr"] .mobile-lang-toggle .mobile-lang-tr,
    html[lang="en"] .mobile-lang-toggle .mobile-lang-en {
      color: rgb(var(--text-color));
      font-weight: 800;
    }
    .mobile-lang-toggle .mobile-lang-sep {
      color: rgb(var(--text-color) / 0.25);
    }
    /* mobile-nav-content stretches so footer sticks bottom */
    .mobile-nav-content {
      display: flex;
      flex-direction: column;
      min-height: 100%;
    }
    [data-mobile-list] { margin-bottom: auto; }
  </style>
</head>
<body class="color-scheme color-scheme--scheme-1">
  <header class={`header ${transparentHeader ? 'header--transparent' : ''}`} id="header">
    <div class="header-inner">
      <div class="header-primary-nav">
        <button class="menu-toggle" id="menuToggle" aria-label="Menu"><span></span><span></span><span></span></button>
        <a href={`${base}shop?sort=newest`} class="nav-link" data-i18n="nav.newIn">YENİ GELENLER</a>
        <a href={`${base}shop`} class="nav-link" data-i18n="nav.shopAll">TÜM ÜRÜNLER</a>
        <a href={`${base}about`} class="nav-link" data-i18n="nav.brand">HAKKIMIZDA</a>
      </div>
      <a href={base} class="header-logo"><span class="logo-text">OVER2YOU</span></a>
      <div class="header-secondary-nav">
        <a href="#" class="nav-link" style="opacity:0;pointer-events:none;">.</a>
        <button id="langSwitch" class="lang-switch">EN</button>
        <button class="icon-btn search-btn" id="searchBtn" aria-label="Search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </button>
        <button class="icon-btn cart-btn" id="cartBtn" aria-label="Cart">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <span class="cart-count" id="cartCount">0</span>
        </button>
      </div>
    </div>
  </header>

  <div class="mobile-nav-overlay" id="mobileNavOverlay"></div>
  <nav class="mobile-nav" id="mobileNav">
    <div class="mobile-nav-header">
      <button class="menu-close" id="menuCloseBtn" aria-label="Close menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"></path></svg>
      </button>
    </div>
    <div class="mobile-nav-content">
      <ul class="nav-list main-nav-list" id="mainNavList" data-mobile-list>
        <li><a href={`${base}shop?sort=newest`} class="mobile-nav-link" data-i18n="nav.newIn">YENİ GELENLER</a></li>
        <li><a href="#" class="mobile-nav-link has-submenu" data-target="shopMenu" data-i18n="nav.shopAll">TÜM ÜRÜNLER <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"></path></svg></a></li>
        <li><a href={`${base}about`} class="mobile-nav-link" data-i18n="nav.brand">HAKKIMIZDA</a></li>
        <li>
          <div class="nav-widget">
            <span class="nav-widget-title" data-i18n="cat.colors">RENKLER:</span>
            <div class="color-swatches">
              {['black','pink','dark','brown','grey','white','red','blue'].map(c => (
                <a href={`${base}shop?color=${c}`} class="color-swatch" style={`background:${
                  {black:'#2a2a2a',pink:'#e8b5ce',dark:'#111',brown:'#5c4033',grey:'#808080',white:'#f5f5f5',red:'#c94c4c',blue:'#6495ed'}[c]
                }`} title={c.charAt(0).toUpperCase()+c.slice(1)}></a>
              ))}
            </div>
          </div>
          <div class="nav-widget">
            <span class="nav-widget-title" data-i18n="cat.categories">KATEGORİLER:</span>
            <div class="category-thumbs">
              <a href={`${base}shop`} class="cat-thumb"><div class="cat-img-box"><span style="font-weight:900;font-size:10px;">O2Y+</span></div><span data-i18n="nav.shopAll">TÜM ÜRÜNLER</span></a>
              <a href={`${base}shop?cat=jackets`} class="cat-thumb"><div class="cat-img-box"><span style="font-weight:900;font-size:10px;">JKT</span></div><span>JACKETS</span></a>
              <a href={`${base}shop?cat=hoodies`} class="cat-thumb"><div class="cat-img-box"><img src={`${base}img/col-hoodies.jpg`} alt="Hoodies" /></div><span data-i18n="cat.hoodies">SWEATSHIRT</span></a>
              <a href={`${base}shop?cat=sweatpants`} class="cat-thumb"><div class="cat-img-box"><img src={`${base}img/col-sweatpants.jpg`} alt="Sweatpants" /></div><span data-i18n="cat.sweatpants">EŞOFMAN</span></a>
              <a href={`${base}shop?cat=crewnecks`} class="cat-thumb"><div class="cat-img-box"><img src={`${base}img/col-crewnecks.jpg`} alt="Crewnecks" /></div><span data-i18n="cat.crewnecks">CREWNECK</span></a>
            </div>
          </div>
        </li>
      </ul>
      <div class="submenu-container" id="shopMenu">
        <button class="submenu-back" aria-label="Back"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"></path></svg> BACK</button>
        <ul class="nav-list">
          <li><a href={`${base}shop`} class="mobile-nav-link" data-i18n="nav.shopAll">TÜM ÜRÜNLER</a></li>
          <li><a href={`${base}shop?cat=jackets`} class="mobile-nav-link">JACKETS</a></li>
          <li><a href={`${base}shop?cat=hoodies`} class="mobile-nav-link" data-i18n="cat.hoodies">SWEATSHIRT</a></li>
          <li><a href={`${base}shop?cat=sweatpants`} class="mobile-nav-link" data-i18n="cat.sweatpants">EŞOFMAN</a></li>
          <li><a href={`${base}shop?cat=crewnecks`} class="mobile-nav-link" data-i18n="cat.crewnecks">CREWNECK</a></li>
          <li><a href={`${base}shop?cat=tshirts`} class="mobile-nav-link" data-i18n="cat.tshirts">TİŞÖRT</a></li>
        </ul>
      </div>
      <div class="mobile-nav-footer">
        <button type="button" class="mobile-lang-toggle" aria-label="Dil değiştir / Change language" onclick="document.getElementById('langSwitch').click(); document.getElementById('mobileNav').classList.remove('active'); document.getElementById('mobileNavOverlay').classList.remove('active'); document.body.style.overflow='';">
          <span class="mobile-lang-tr">TÜRKÇE</span>
          <span class="mobile-lang-sep">·</span>
          <span class="mobile-lang-en">ENGLISH</span>
        </button>
      </div>
    </div>
  </nav>

  <slot />

  <!-- Search Modal -->
  <div class="search-modal" id="searchModal">
    <div class="search-modal-inner">
      <input type="text" placeholder="Ara..." data-i18n="search.placeholder" id="searchInput" autocomplete="off" />
      <button id="searchClose" aria-label="Close"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    </div>
    <div id="searchResults"></div>
  </div>

  <!-- Cart Drawer -->
  <div class="cart-overlay" id="cartOverlay"></div>
  <div class="cart-drawer" id="cartDrawer">
    <div class="cart-drawer-header"><h3 data-i18n="cart.title">SEPET</h3><button class="cart-drawer-close" id="cartClose"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
    <div class="cart-drawer-body" id="cartBody"><p class="cart-empty-msg" data-i18n="cart.empty">Sepetiniz boş</p></div>
    <div class="cart-drawer-footer" id="cartFooter" style="display:none">
      <div class="cart-total-row"><span data-i18n="cart.total">Toplam</span><span id="cartTotal">₺0.00</span></div>
      <button class="btn-checkout" data-i18n="cart.checkout">ÖDEMEYE GEÇ</button>
    </div>
  </div>

  <Footer />

  <script is:inline src={`${base}js/i18n.js?v=6`}></script>
  <script is:inline src={`${base}js/app.js?v=7`}></script>
  <script is:inline src={`${base}js/carousel-3d.js?v=12`}></script>
</body>
</html>
