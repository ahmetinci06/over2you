---
interface Props {
  title?: string;
  transparentHeader?: boolean;
  description?: string;
}

const { title = 'Over2You | OFFICIAL WEBSITE', transparentHeader = false, description = 'Over2You — Premium streetwear and essentials.' } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
---
<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${base}img/hero-desktop-1.jpg`} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="stylesheet" href={`${base}css/style.css`} />
  </head>
  <body class="color-scheme color-scheme--scheme-1">
    <header class={`header ${transparentHeader ? 'header--transparent' : ''}`} id="header">
      <div class="header-inner">
        <div class="header-primary-nav">
          <button class="menu-toggle" id="menuToggle" aria-label="Menu"><span></span><span></span><span></span></button>
          <a href={`${base}`} class="nav-link">NEW IN</a>
          <div class="nav-dropdown" id="desktopShopNav"><a href="#" class="nav-link nav-dropdown-trigger">SHOP ALL</a></div>
          <a href={`${base}pages/shop.html`} class="nav-link">OVER2YOU+</a>
          <a href="#" class="nav-link">COLLECTIONS</a>
          <a href={`${base}pages/shop.html?cat=women`} class="nav-link">WOMEN</a>
          <a href="#" class="nav-link">SPORTS</a>
          <a href={`${base}pages/about.html`} class="nav-link">BRAND</a>
        </div>
        <a href={`${base}`} class="header-logo"><span class="logo-text">OVER2YOU</span></a>
        <div class="header-secondary-nav">
          <a href="#" class="nav-link" style="opacity:0;pointer-events:none;">.</a>
          <button class="icon-btn search-btn" id="searchBtn" aria-label="Search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </button>
          <button class="icon-btn cart-btn" id="cartBtn" aria-label="Cart">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
            <span class="cart-count" id="cartCount">0</span>
          </button>
        </div>
      </div>
    </header>

    <!-- Mobile Nav -->
    <div class="mobile-nav-overlay" id="mobileNavOverlay"></div>
    <nav class="mobile-nav" id="mobileNav">
      <div class="mobile-nav-header">
        <button class="menu-close" id="menuCloseBtn" aria-label="Close menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6L6 18M6 6l12 12"></path></svg>
        </button>
      </div>
      <div class="mobile-nav-content">
        <ul class="nav-list main-nav-list" id="mainNavList">
          <li><a href={`${base}`} class="mobile-nav-link">NEW IN</a></li>
          <li><a href="#" class="mobile-nav-link has-submenu" data-target="shopMenu">SHOP ALL <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"></path></svg></a></li>
          <li><a href="#" class="mobile-nav-link has-submenu">OVER2YOU+ <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"></path></svg></a></li>
          <li>
            <div class="nav-widget">
              <span class="nav-widget-title">COLORS:</span>
              <div class="color-swatches">
                <a href={`${base}pages/shop.html?color=black`} class="color-swatch" style="background:#2a2a2a" title="Black"></a>
                <a href={`${base}pages/shop.html?color=pink`} class="color-swatch" style="background:#e8b5ce" title="Pink"></a>
                <a href={`${base}pages/shop.html?color=dark`} class="color-swatch" style="background:#111" title="Dark"></a>
                <a href={`${base}pages/shop.html?color=brown`} class="color-swatch" style="background:#5c4033" title="Brown"></a>
                <a href={`${base}pages/shop.html?color=grey`} class="color-swatch" style="background:#808080" title="Grey"></a>
                <a href={`${base}pages/shop.html?color=white`} class="color-swatch" style="background:#f5f5f5" title="White"></a>
                <a href={`${base}pages/shop.html?color=red`} class="color-swatch" style="background:#c94c4c" title="Red"></a>
                <a href={`${base}pages/shop.html?color=blue`} class="color-swatch" style="background:#6495ed" title="Blue"></a>
              </div>
            </div>
            <div class="nav-widget">
              <span class="nav-widget-title">CATEGORIES:</span>
              <div class="category-thumbs">
                <a href={`${base}pages/shop.html`} class="cat-thumb"><div class="cat-img-box"><span style="font-weight:900;font-size:10px;">O2Y+</span></div><span>SHOP ALL</span></a>
                <a href={`${base}pages/shop.html?cat=hoodies`} class="cat-thumb"><div class="cat-img-box"><img src={`${base}img/col-hoodies.jpg`} alt="Hoodies" /></div><span>HOODIES</span></a>
                <a href={`${base}pages/shop.html?cat=sweatpants`} class="cat-thumb"><div class="cat-img-box"><img src={`${base}img/col-sweatpants.jpg`} alt="Sweatpants" /></div><span>SWEATPANTS</span></a>
                <a href={`${base}pages/shop.html?cat=crewnecks`} class="cat-thumb"><div class="cat-img-box"><img src={`${base}img/col-crewnecks.jpg`} alt="Crewnecks" /></div><span>CREWNECKS</span></a>
              </div>
            </div>
          </li>
          <li><a href={`${base}pages/shop.html?cat=women`} class="mobile-nav-link">WOMEN</a></li>
          <li><a href="#" class="mobile-nav-link">SPORTS</a></li>
          <li><a href={`${base}pages/about.html`} class="mobile-nav-link has-submenu">BRAND <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"></path></svg></a></li>
        </ul>
        <div class="submenu-container" id="shopMenu">
          <button class="submenu-back" aria-label="Back"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"></path></svg> BACK</button>
          <ul class="nav-list">
            <li><a href={`${base}pages/shop.html`} class="mobile-nav-link">SHOP ALL</a></li>
            <li><a href={`${base}pages/shop.html?cat=basics`} class="mobile-nav-link">BASICS</a></li>
            <li><a href={`${base}pages/shop.html?cat=tops`} class="mobile-nav-link">TOPS</a></li>
            <li><a href={`${base}pages/shop.html?cat=bottoms`} class="mobile-nav-link">BOTTOMS</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <slot />

    <!-- Search Modal -->
    <div class="search-modal" id="searchModal">
      <div class="search-modal-inner">
        <input type="text" placeholder="Search..." id="searchInput" autocomplete="off" />
        <button id="searchClose" aria-label="Close search"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
      <div id="searchResults"></div>
    </div>

    <!-- Cart Drawer -->
    <div class="cart-overlay" id="cartOverlay"></div>
    <div class="cart-drawer" id="cartDrawer">
      <div class="cart-drawer-header"><h3>CART</h3><button class="cart-drawer-close" id="cartClose"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
      <div class="cart-drawer-body" id="cartBody"><p class="cart-empty-msg">Your cart is empty</p></div>
      <div class="cart-drawer-footer" id="cartFooter" style="display:none">
        <div class="cart-total-row"><span>Total</span><span id="cartTotal">€0.00</span></div>
        <button class="btn-checkout">CHECKOUT</button>
      </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>SUPPORT</h4>
          <p>FOR QUESTIONS REGARDING ORDERS PLEASE CONTACT</p>
          <a href="mailto:SUPPORT@OVER2YOU.COM">SUPPORT@OVER2YOU.COM</a>
          <p>(MO-FR)</p><br>
          <a href="#">JOIN THE Over2You WHATSAPP CHANNEL</a>
          <p>EARLY ACCESS, DISCOUNTS & SPECIALS</p>
          <a href="#">JOIN NOW →</a>
        </div>
        <div class="footer-col"><h4>Service</h4><a href="#">SUPPORT</a><a href="#">Returns</a><a href="#">Shipping</a><a href="#">Order Tracking</a></div>
        <div class="footer-col"><h4>Legal</h4><a href="#">Imprint</a><a href="#">Privacy Policy</a><a href="#">Terms of Service</a><a href="#">Refund Policy</a></div>
        <div class="footer-col">
          <h4>More</h4><a href="#">SOCIALS</a>
          <div class="social-links" style="margin-top:0.75rem">
            <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
            <a href="#" aria-label="TikTok"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.53v-3.4a4.85 4.85 0 01-.81-.05l-.38-.06z"/></svg></a>
            <a href="#" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
          </div>
          <br/><p>SECURE PAYMENTS</p>
        </div>
      </div>
      <div class="footer-bottom"><p>© 2026 - Over2You. All rights reserved.</p></div>
    </footer>

    <script is:inline src={`${base}js/app.js`}></script>
  </body>
</html>
