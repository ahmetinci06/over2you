---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Over2You | OFFICIAL WEBSITE" transparentHeader={true}>
  <!-- Hero Slideshow -->
  <section class="slideshow" id="slideshow">
    <div class="slideshow-track" id="slideshowTrack">
      <div class="slide">
        <img class="slide-img mobile" src={`${base}img/hero-mobile-1.jpg`} alt="New Colors" />
        <img class="slide-img desktop" src={`${base}img/hero-desktop-1.jpg`} alt="New Colors" />
        <div class="slide-overlay">
          <span class="logo-text" style="color:#fff;margin-bottom:1.5rem;font-size:3.5rem;">OVER2YOU</span>
          <a href={`${base}pages/shop.html`} class="slide-btn">NEW COLORS ONLINE</a>
        </div>
      </div>
      <div class="slide">
        <img class="slide-img mobile" src={`${base}img/hero-mobile-2.jpg`} alt="Collection" />
        <img class="slide-img desktop" src={`${base}img/hero-desktop-2.jpg`} alt="Collection" />
        <div class="slide-overlay">
          <span class="logo-text" style="color:#fff;margin-bottom:1.5rem;font-size:3.5rem;">OVER2YOU</span>
          <a href={`${base}pages/shop.html?cat=women`} class="slide-btn">WOMEN</a>
        </div>
      </div>
      <div class="slide">
        <img class="slide-img mobile" src={`${base}img/hero-mobile-3.jpg`} alt="Collection" />
        <img class="slide-img desktop" src={`${base}img/hero-desktop-3.jpg`} alt="Collection" />
        <div class="slide-overlay">
          <span class="logo-text" style="color:#fff;margin-bottom:1.5rem;font-size:3.5rem;">OVER2YOU</span>
          <a href={`${base}pages/shop.html`} class="slide-btn">SHOP NOW</a>
        </div>
      </div>
    </div>
    <button class="slideshow-arrow prev" id="slidePrev"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg></button>
    <button class="slideshow-arrow next" id="slideNext"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg></button>
    <div class="slideshow-dots" id="slideshowDots">
      <button class="slideshow-dot active" data-index="0"></button>
      <button class="slideshow-dot" data-index="1"></button>
      <button class="slideshow-dot" data-index="2"></button>
    </div>
  </section>

  <!-- Media Grid -->
  <section class="media-grid">
    <a href={`${base}pages/shop.html`} class="media-grid-item">
      <img src={`${base}img/grid-1.jpg`} alt="Over2You+ Basics" />
      <div class="media-grid-overlay">
        <span class="logo-text" style="color:#fff;font-size:24px;margin-bottom:0.5rem;">OVER2YOU+</span>
        <span class="media-grid-title">Basics</span>
      </div>
    </a>
    <a href={`${base}pages/shop.html?cat=women`} class="media-grid-item">
      <img src={`${base}img/grid-2.jpg`} alt="Women" />
      <div class="media-grid-overlay">
        <span class="logo-text" style="color:#fff;font-size:24px;margin-bottom:0.5rem;">OVER2YOU</span>
        <span class="media-grid-title">WOMEN</span>
      </div>
    </a>
    <a href="#" class="media-grid-item">
      <img src={`${base}img/grid-3.jpg`} alt="Over2You Active" />
      <div class="media-grid-overlay">
        <span class="logo-text" style="color:#fff;font-size:24px;margin-bottom:0.5rem;">O2Y ACTIVE</span>
        <span class="media-grid-title">Over2You Active</span>
      </div>
    </a>
  </section>

  <!-- Newsletter -->
  <section class="newsletter-section">
    <h2>SIGN UP TO THE Over2You NEWSLETTER</h2>
    <form class="newsletter-form" id="newsletterForm">
      <input type="email" placeholder="Enter your email" required />
      <button type="submit">SUBSCRIBE</button>
    </form>
  </section>
</Layout>
