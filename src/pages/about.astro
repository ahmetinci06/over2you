---
import Layout from '../layouts/Layout.astro';
const base = (import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/');
---
<Layout title="Hakkımızda — Over2You" description="Over2You — premium temel parçalar, zamansız tasarım. Organik pamuk, 400gsm ağırlık, hızlı moda yok.">

  <!-- 1. HERO -->
  <section class="about-hero">
    <img
      src={`${base}img/about/hero.jpg?v=2`}
      alt="over2you - zamansız parçalar"
      class="about-hero-img"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="about-hero-overlay">
      <h1>OVER2YOU HAKKINDA</h1>
      <p class="about-hero-tagline">zamansız parçalar, tavizsiz kalite</p>
    </div>
  </section>

  <!-- 2. STORY -->
  <section class="about-story">
    <p>over2you, premium temel parçaların herkes için erişilebilir olması gerektiği inancıyla kuruldu. doğal organik pamuktan üretilmiş, hem giyene hem doğaya saygılı, zamansız parçalar tasarlıyoruz.</p>
    <p>her parçamız, fırçalı iç astarlı 400gsm ağır organik pamuktan üretiliyor. tavizsiz. hızlı moda yok. sadece her gün giymek isteyeceğin, yıllarca dayanacak parçalar.</p>
  </section>

  <!-- 3. VALUES GRID -->
  <section class="about-values">
    <div class="about-values-grid">
      <div class="about-value-card">
        <svg class="about-value-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M11 20A7 7 0 0 1 4 13C4 8 8 5 12 4C16 5 20 8 20 13A7 7 0 0 1 13 20"/>
          <path d="M12 4 V20"/>
        </svg>
        <h3>ORGANİK PAMUK</h3>
        <p>sertifikalı doğal kumaş, kimyasal kalıntı yok.</p>
      </div>
      <div class="about-value-card">
        <svg class="about-value-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="6" y1="6" x2="6" y2="18"/>
          <line x1="18" y1="6" x2="18" y2="18"/>
          <line x1="6" y1="12" x2="18" y2="12"/>
          <line x1="3" y1="9" x2="3" y2="15"/>
          <line x1="21" y1="9" x2="21" y2="15"/>
        </svg>
        <h3>400GSM AĞIRLIK</h3>
        <p>yoğun dokuma, uzun ömür, koruyucu his.</p>
      </div>
      <div class="about-value-card">
        <svg class="about-value-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="3 7 7 3 11 7"/>
          <path d="M7 3 V14 a5 5 0 0 0 5 5 h2"/>
          <polyline points="21 17 17 21 13 17"/>
          <path d="M17 21 V10 a5 5 0 0 0 -5 -5 h-2"/>
        </svg>
        <h3>HIZLI MODA YOK</h3>
        <p>sınırlı koleksiyon, bilinçli üretim, israf yok.</p>
      </div>
    </div>
  </section>

  <!-- 4. LIFESTYLE -->
  <section class="about-lifestyle" style={`background-image: url(${base}img/about/lifestyle.jpg?v=2);`} aria-label="Over2You koleksiyonu görseli"></section>

  <!-- 5. CTA -->
  <section class="about-cta">
    <p class="about-cta-line">kendin için bir parça seç.</p>
    <a href={`${base}shop`} class="about-cta-btn">KOLEKSİYONU KEŞFET</a>
  </section>

</Layout>

<style is:inline>
  /* ===== Hero =====
     style.css:1336 has a legacy .about-hero rule with max-width:50rem +
     margin:0 auto from a prior about-page design — explicitly reset both
     here so this hero spans full-viewport width.
     Image is now a real <img> (was background-image) so the browser can
     load it at intrinsic resolution and cache properly. ::after applies
     a gradient over the image for tagline contrast. */
  .about-hero {
    position: relative;
    min-height: 60vh;
    max-width: none;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
    padding: 4rem 1rem;
    overflow: hidden;
  }
  .about-hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%; /* preserve faces / upper subject area */
    z-index: 0;
  }
  .about-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.20) 40%, rgba(0, 0, 0, 0.55) 100%);
    pointer-events: none;
    z-index: 1;
  }
  .about-hero-overlay {
    position: relative;
    z-index: 2;
    max-width: 780px;
  }
  .about-hero h1 {
    font: var(--heading-font-style) 900 3rem/1.05 var(--heading-font-family);
    text-transform: uppercase;
    letter-spacing: var(--heading-letter-spacing);
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.55);
    margin: 0 0 0.85rem;
  }
  /* style.css:1351 has a global .about-hero p {color: rgb(var(--text-color)/0.65)}
     that overrides .about-hero-tagline by descendant-element specificity
     (0,1,1 vs 0,1,0). Bump our selector to .about-hero .about-hero-tagline
     (0,2,0) so #fff sticks. */
  .about-hero .about-hero-tagline {
    font-size: var(--text-base);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: #fff;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.7);
    line-height: 1.5;
    margin: 0;
  }

  /* ===== Story ===== */
  .about-story {
    max-width: 800px;
    margin: 0 auto;
    padding: 5rem 1.5rem;
    line-height: 1.85;
  }
  .about-story p {
    font-size: var(--text-base);
    color: rgb(var(--text-color)/0.78);
    margin: 0 0 1.5rem;
  }
  .about-story p:last-child { margin-bottom: 0; }

  /* ===== Values grid ===== */
  .about-values {
    background: rgb(var(--text-color)/0.03);
    border-top: 1px solid rgb(var(--border-color)/0.15);
    border-bottom: 1px solid rgb(var(--border-color)/0.15);
    padding: 5rem 1.5rem;
  }
  .about-values-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }
  .about-value-card { text-align: center; }
  .about-value-icon {
    width: 44px;
    height: 44px;
    color: rgb(var(--text-color));
    margin: 0 auto 1.1rem;
    display: block;
  }
  .about-value-card h3 {
    font: var(--heading-font-style) 800 var(--text-base)/1.25 var(--heading-font-family);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.65rem;
  }
  .about-value-card p {
    font-size: var(--text-sm);
    color: rgb(var(--text-color)/0.65);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 24em;
  }

  /* ===== Lifestyle ===== */
  .about-lifestyle {
    min-height: 40vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  /* ===== CTA ===== */
  /* style.css:1380 .about-cta has border-top — reset to avoid stacking
     with the .about-values border-bottom right above. */
  .about-cta {
    max-width: 800px;
    margin: 0 auto;
    padding: 5rem 1.5rem;
    text-align: center;
    border-top: 0;
  }
  .about-cta-line {
    font: var(--heading-font-style) 700 1.5rem/1.3 var(--heading-font-family);
    margin: 0 0 1.75rem;
    color: rgb(var(--text-color));
  }
  .about-cta-btn {
    display: inline-block;
    padding: 1rem 2.75rem;
    background: rgb(var(--text-color));
    color: rgb(var(--background));
    font: var(--heading-font-style) 800 var(--text-sm)/1 var(--heading-font-family);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .about-cta-btn:hover { opacity: 0.85; }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .about-hero { min-height: 50vh; padding: 3rem 1rem; }
    .about-hero h1 { font-size: 2rem; line-height: 1.1; }
    .about-hero-tagline { font-size: var(--text-sm); }
    .about-story { padding: 3.5rem 1.25rem; }
    .about-values { padding: 3.5rem 1.25rem; }
    .about-values-grid { grid-template-columns: 1fr; gap: 2.25rem; }
    .about-cta { padding: 3.5rem 1.25rem; }
    .about-cta-line { font-size: 1.2rem; }
    .about-lifestyle { min-height: 32vh; }
  }
</style>
