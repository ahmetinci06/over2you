---
import BaseLayout from '../../layouts/base-layout.astro';
import ProductSpinner from '../../components/product-spinner.astro';
import Accordion from '../../components/accordion.astro';
import ProductCard from '../../components/product-card.astro';
import { getProduct, getAllProducts } from '../../lib/products';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');

const product = await getProduct(slug);
if (!product) return Astro.redirect('/');

const { name, price, currency, colors, sizes, in_stock: inStock, badge, images, has360, description, material, care, model_info: modelInfo } = product;

const formattedPrice = new Intl.NumberFormat('tr-TR', {
  minimumFractionDigits: 2,
}).format(price);

// Related products
const allProducts = await getAllProducts();
const related = allProducts
  .filter((p) => p.slug !== slug && p.collection === product.collection)
  .slice(0, 4);
---

<BaseLayout title={name}>
  <div class="pt-24 lg:pt-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="text-xs text-brand-muted mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href={`/collections/${product.collection}`} class="hover:text-white transition-colors capitalize">{product.collection}</a>
        <span class="mx-2">/</span>
        <span class="text-white">{name}</span>
      </nav>

      <div class="lg:grid lg:grid-cols-2 lg:gap-12">
        <!-- Product Images -->
        <div class="space-y-4">
          {has360 ? (
            <ProductSpinner
              folder={`/images/products/${slug}/360`}
              imageCount={36}
              productName={name}
            />
          ) : (
            <div class="aspect-square bg-brand-card flex items-center justify-center">
              <div class="text-center">
                <span class="text-lg text-brand-muted uppercase tracking-wider">{name}</span>
                <p class="text-xs text-brand-muted mt-2">Product Image</p>
              </div>
            </div>
          )}

          <!-- Thumbnail strip -->
          <div class="grid grid-cols-4 gap-2">
            {[1, 2, 3, 4].map((i) => (
              <div class="aspect-square bg-brand-card border border-brand-border flex items-center justify-center cursor-pointer hover:border-white transition-colors">
                <span class="text-[10px] text-brand-muted">{i}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Product Info -->
        <div class="mt-8 lg:mt-0">
          {badge && (
            <span class={`inline-block mb-3 ${
              badge === 'NEW' ? 'badge-new' :
              badge === 'LAST STOCK' ? 'badge-last-stock' :
              'badge-updated'
            }`}>
              {badge}
            </span>
          )}

          <h1 class="text-2xl md:text-3xl font-bold uppercase tracking-wider">{name}</h1>
          <p class="text-xl mt-2">{`\u20BA${formattedPrice}`}</p>

          <!-- Color Selector -->
          <div class="mt-6">
            <h3 class="text-xs font-semibold uppercase tracking-wider mb-3">Color</h3>
            <div class="flex gap-2">
              {colors.map((color) => (
                <button
                  class="w-8 h-8 border-2 border-white ring-1 ring-brand-border"
                  style={`background-color: ${color === 'anthracite' ? '#383838' : color === 'navy' ? '#1a1a4e' : color === 'grey' ? '#888' : color === 'olive' ? '#556B2F' : color}`}
                  title={color}
                  aria-label={`Color: ${color}`}
                >
                </button>
              ))}
            </div>
          </div>

          <!-- Size Selector -->
          <div class="mt-6">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-xs font-semibold uppercase tracking-wider">Size</h3>
              <button class="text-xs text-brand-muted underline hover:text-white transition-colors">Size Guide</button>
            </div>
            <div class="flex flex-wrap gap-2">
              {sizes.map((size, i) => (
                <button
                  class={`min-w-[48px] h-10 border text-sm font-medium transition-colors ${
                    i === 0
                      ? 'border-white bg-white text-black'
                      : 'border-brand-border hover:border-white'
                  }`}
                  data-size={size}
                >
                  {size}
                </button>
              ))}
            </div>
          </div>

          <!-- Add to Cart -->
          <div class="mt-8">
            <button
              class={`w-full py-4 text-sm font-semibold uppercase tracking-wider transition-colors snipcart-add-item ${
                inStock
                  ? 'bg-white text-black hover:bg-gray-200'
                  : 'bg-brand-border text-brand-muted cursor-not-allowed'
              }`}
              disabled={!inStock}
              data-item-id={slug}
              data-item-name={name}
              data-item-price={price}
              data-item-url={`/products/${slug}`}
              data-item-description={description}
              data-item-image={images[0]}
              data-item-currency="TRY"
            >
              {inStock ? 'Add to Cart' : 'Sold Out'}
            </button>
          </div>

          <!-- Model Info -->
          <p class="text-xs text-brand-muted mt-4">{modelInfo}</p>

          <!-- Accordions -->
          <div class="mt-8">
            <Accordion title="Product Information" open>
              <p>{description}</p>
              <p class="mt-2"><strong>Material:</strong> {material}</p>
            </Accordion>

            <Accordion title="Care Instructions">
              <ul class="space-y-1">
                {care.map((instruction) => (
                  <li class="flex items-center gap-2">
                    <span class="w-1 h-1 bg-brand-muted rounded-full"></span>
                    {instruction}
                  </li>
                ))}
              </ul>
            </Accordion>

            <Accordion title="Size Information">
              <p>Our garments follow a relaxed, oversized fit. We recommend choosing your regular size for the intended look, or sizing down for a more fitted style.</p>
              <div class="mt-3 text-xs">
                <table class="w-full">
                  <thead>
                    <tr class="border-b border-brand-border">
                      <th class="text-left py-2">Size</th>
                      <th class="text-left py-2">Chest (cm)</th>
                      <th class="text-left py-2">Length (cm)</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr class="border-b border-brand-border"><td class="py-2">S</td><td>112</td><td>70</td></tr>
                    <tr class="border-b border-brand-border"><td class="py-2">M</td><td>118</td><td>73</td></tr>
                    <tr class="border-b border-brand-border"><td class="py-2">L</td><td>124</td><td>76</td></tr>
                    <tr class="border-b border-brand-border"><td class="py-2">XL</td><td>130</td><td>79</td></tr>
                  </tbody>
                </table>
              </div>
            </Accordion>

            <Accordion title="Shipping & Returns">
              <p>Free shipping on orders over 1,000 TL. Standard delivery 2-4 business days within Turkey.</p>
              <p class="mt-2">Returns accepted within 14 days of delivery. Items must be unworn with original tags attached.</p>
            </Accordion>
          </div>
        </div>
      </div>

      <!-- Related Products -->
      {related.length > 0 && (
        <section class="mt-20">
          <h2 class="text-lg font-semibold uppercase tracking-wider mb-8">You Might Also Like</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
            {related.map((p) => (
              <ProductCard
                name={p.name}
                slug={p.slug}
                price={p.price}
                images={p.images}
                badge={p.badge}
                sizes={p.sizes}
                inStock={p.in_stock}
              />
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</BaseLayout>

<script is:inline>
  // Size selector interaction
  document.querySelectorAll('[data-size]').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('[data-size]').forEach((b) => {
        b.classList.remove('border-white', 'bg-white', 'text-black');
        b.classList.add('border-brand-border');
      });
      btn.classList.remove('border-brand-border');
      btn.classList.add('border-white', 'bg-white', 'text-black');
    });
  });
</script>
