---
import Layout from '../layouts/Layout.astro';
const base = (import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/');
---
<Layout title="Product — Over2You" description="Over2You — premium temel parçalar.">
  <div class="pd-page" style="padding:6rem var(--container-gutter) 4rem;max-width:1400px;margin:0 auto;">
    <div class="product-layout" id="productLayout">
      <p style="text-align:center;padding:4rem;color:rgb(var(--text-color)/0.4);">Loading product...</p>
    </div>
  </div>

  <!-- Size guide modal — outside #productLayout so render() doesn't wipe it.
       Triggered by the accordion's "Beden Tablosu" item (which calls
       this.classList.add('open')). -->
  <div id="sizeGuideModal" class="size-guide-modal" onclick="if(event.target===this) this.classList.remove('open');" role="dialog" aria-labelledby="sizeGuideTitle" aria-modal="true">
    <div class="size-guide-modal-inner">
      <button class="size-guide-modal-close" type="button" onclick="document.getElementById('sizeGuideModal').classList.remove('open');" aria-label="Kapat">×</button>
      <h2 id="sizeGuideTitle">BEDEN TABLOSU</h2>
      <p class="size-guide-intro">Vücut ölçülerinize göre seçim önerisi. Ürün ölçüleri parça başına değişebilir; sıkı/oversize tercih ediyorsanız bir alt/üst beden seçebilirsiniz.</p>
      <div class="size-guide-table-wrap">
        <table class="size-guide-table">
          <thead>
            <tr>
              <th>Beden</th>
              <th>Göğüs (cm)</th>
              <th>Bel (cm)</th>
              <th>Kalça (cm)</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>XS</td><td>82–86</td><td>62–66</td><td>88–92</td></tr>
            <tr><td>S</td><td>86–90</td><td>66–70</td><td>92–96</td></tr>
            <tr><td>M</td><td>90–96</td><td>70–76</td><td>96–102</td></tr>
            <tr><td>L</td><td>96–102</td><td>76–82</td><td>102–108</td></tr>
            <tr><td>XL</td><td>102–108</td><td>82–88</td><td>108–114</td></tr>
            <tr><td>XXL</td><td>108–114</td><td>88–94</td><td>114–120</td></tr>
          </tbody>
        </table>
      </div>
      <p class="size-guide-note">Müşteri-onaylı ürün-bazlı ölçüler eklenince bu tablo güncellenecek (genel referans).</p>
    </div>
  </div>

  <script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const MAX_WAIT_MS = 4000;
    const POLL_MS = 80;
    const started = Date.now();

    const tryRender = () => {
      if (!window.productsReady) {
        if (Date.now() - started > MAX_WAIT_MS) { render(); return; }
        setTimeout(tryRender, POLL_MS);
        return;
      }
      render();
    };

    function attrJSON(obj) {
      return JSON.stringify(obj)
        .replace(/&/g, '&amp;')
        .replace(/'/g, '&#39;');
    }

    function render() {
      const params = new URLSearchParams(window.location.search);
      const id = parseInt(params.get('id'));
      const list = (window.products && window.products.length) ? window.products : [];
      const product = list.find(p => p.id === id);
      const layout = document.getElementById('productLayout');

      if (!product) {
        layout.innerHTML = '<div style="text-align:center;padding:4rem;"><h2 style="font:var(--heading-font-style) 800 1.5rem/1.2 var(--heading-font-family);margin-bottom:1rem;">Product Not Found</h2><a href="' + window.O2Y_BASE + 'shop" class="btn-primary" style="display:inline-block;padding:0.75rem 2rem;">BACK TO SHOP</a></div>';
        return;
      }

      // SEO: prefer product.seo.metaTitle / metaDescription, fall back to defaults
      document.title = (product.seo && product.seo.metaTitle) || (product.name + ' — Over2You');
      const metaDesc = (product.seo && product.seo.metaDescription) || (product.description || '').slice(0, 160);
      let metaEl = document.querySelector('meta[name="description"]');
      if (!metaEl) { metaEl = document.createElement('meta'); metaEl.setAttribute('name', 'description'); document.head.appendChild(metaEl); }
      metaEl.setAttribute('content', metaDesc);
      const B = window.O2Y_BASE;
      const imgBase = B + 'img/';
      const related = list.filter(r => r.category === product.category && r.id !== product.id).slice(0, 8);

      const frames360 = Array.isArray(product.images360) ? product.images360 : [];
      const has360 = frames360.length >= 4 && frames360.every(f => f && typeof f === 'object' && f.src);

      // Related products for below-fold section: max 4 from other products,
      // shuffled so repeat visits feel fresh. Single-product fallback handled
      // in the section template.
      const otherProducts = list.filter(p => p.id !== product.id);
      const shuffled = otherProducts.slice().sort(() => Math.random() - 0.5);
      const relatedSlice = shuffled.slice(0, 4);

      // Variant colors. New schema: product.colors[] — each entry has
      // {id, name, hex, default} + optional advanced fields (images,
      // images360, stock, priceOverride). Legacy products without colors[]
      // get a synthesized 1-entry array from the top-level color/colorName.
      const variantColors = (Array.isArray(product.colors) && product.colors.length > 0)
        ? product.colors
        : [{ id: 'default', name: product.colorName || '—', hex: product.color || '#000000', default: true }];
      const defaultColorIdx = Math.max(0, variantColors.findIndex(c => c.default));
      const defaultColor = variantColors[defaultColorIdx] || variantColors[0];

      const framesData = has360
        ? frames360
        : (Array.isArray(product.images) ? product.images : []);

      const thumbsSource = has360
        ? frames360.map((f, i) => ({ src: f.src, label: f.label || ('View ' + (i+1)), flip: !!f.flip }))
        : (product.images || []).map((src, i) => ({ src, label: 'View ' + (i+1), flip: false }));

      const N = thumbsSource.length;
      const showThumbs = N >= 2;

      const thumbsHTML = showThumbs ? thumbsSource.map((t, i) => `
        <button class="pd-thumb${i === 0 ? ' active' : ''}" type="button" data-idx="${i}" aria-label="${t.label}">
          <img src="${imgBase}${t.src}" alt="${t.label}" style="${t.flip ? 'transform:scaleX(-1);' : ''}">
        </button>
      `).join('') : '';

      const stageHTML =
        `<carousel-3d data-frames='${attrJSON(framesData)}' data-img-base="${imgBase}" data-has360="${has360}"></carousel-3d>`;

      layout.innerHTML = `
        <div class="product-breadcrumb" style="font-size:11px;color:rgb(var(--text-color)/0.4);margin-bottom:1.5rem;">
          <a href="${B}" style="color:inherit;">Home</a> /
          <a href="${B}shop?cat=${product.category}" style="color:inherit;">${product.category.charAt(0).toUpperCase()+product.category.slice(1)}</a> /
          <span style="color:rgb(var(--text-color)/0.7);">${product.name}</span>
        </div>
        <div class="product-grid-layout">
          <div class="pd-gallery${showThumbs ? '' : ' pd-gallery-no-thumbs'}">
            ${showThumbs ? `<div class="pd-thumbs" id="pdThumbs">${thumbsHTML}</div>` : ''}
            <div class="pd-stage-wrap">${stageHTML}</div>
          </div>
          <div class="pd-info">
            <h1 style="font:var(--heading-font-style) 800 1.5rem/1.2 var(--heading-font-family);text-transform:uppercase;letter-spacing:0.03em;margin-bottom:0.75rem;">${product.name}</h1>
            ${product.sku ? `<p style="font-size:11px;color:rgb(var(--text-color)/0.45);letter-spacing:0.04em;margin-bottom:0.6rem;">SKU: ${product.sku}</p>` : ''}
            <p style="font-size:var(--text-base);margin-bottom:1rem;">€${product.price.toFixed(2)}</p>
            ${product.badge ? `<span style="display:inline-block;padding:3px 8px;font-size:10px;font-weight:700;background:rgb(var(--text-color));color:rgb(var(--background));margin-bottom:1.25rem;">${product.badge}</span>` : ''}

            <div class="pdp-color-swatches">
              <span class="pdp-color-label">RENK: <strong id="activeColorName">${defaultColor.name}</strong></span>
              <div class="swatch-row">
                ${variantColors.map((c, idx) => `
                  <button type="button" class="pdp-color-swatch${idx === defaultColorIdx ? ' active' : ''}" data-color-idx="${idx}" data-color-id="${c.id}" aria-label="${c.name}" title="${c.name}">
                    <span class="swatch-circle" style="background:${c.hex};"></span>
                    ${(Array.isArray(c.images) && c.images.length > 0) ? `<span class="swatch-thumb" style="background-image:url(${imgBase}${c.images[0]});"></span>` : ''}
                  </button>
                `).join('')}
              </div>
            </div>

            <div style="margin-bottom:1.25rem;" id="sizeSection">
              <span style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:rgb(var(--text-color)/0.5);display:block;margin-bottom:0.5rem;">SIZE:</span>
              <div style="display:flex;gap:6px;flex-wrap:wrap;" id="sizeButtons">
                ${product.sizes.map(s => `<button class="size-btn" data-size="${s}" style="padding:0.5rem 1rem;border:1px solid rgb(var(--border-color));background:transparent;font:var(--heading-font-style) 600 11px/1 var(--heading-font-family);cursor:pointer;transition:all 0.2s;">${s}</button>`).join('')}
              </div>
            </div>

            ${product.outOfStock
              ? `<div class="pdp-stock pdp-stock--oos">
                  <span class="pdp-stock-dot" aria-hidden="true" style="background:#dc3545"></span>
                  <strong>Stokta Yok</strong> <span>— stok yenilendiğinde haber veririz</span>
                </div>`
              : `<div class="pdp-stock">
                  <span class="pdp-stock-dot" aria-hidden="true"></span>
                  <strong>Stokta</strong> <span>— ${(typeof product.stockQty === 'number' && product.stockQty > 0 && product.stockQty < 10) ? `son ${product.stockQty} adet` : '3-5 iş günü içinde kargoda'}</span>
                </div>`
            }

            <button id="addToCartBtn" ${product.outOfStock ? 'disabled' : ''} style="width:100%;padding:1rem;background:${product.outOfStock ? 'rgb(var(--text-color)/0.2)' : 'rgb(var(--button-background))'};color:${product.outOfStock ? 'rgb(var(--text-color)/0.5)' : 'rgb(var(--button-text-color))'};border:none;font:var(--heading-font-style) 800 var(--text-sm)/1.65 var(--heading-font-family);text-transform:uppercase;letter-spacing:0.03em;cursor:${product.outOfStock ? 'not-allowed' : 'pointer'};transition:all 0.3s;margin-bottom:0.85rem;">${product.outOfStock ? 'STOKTA YOK' : 'ADD TO CART'}</button>

            <div class="pdp-banner">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="23 4 23 10 17 10"/>
                <polyline points="1 20 1 14 7 14"/>
                <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
              </svg>
              <span>14 gün ücretsiz değişim hakkı</span>
            </div>

            <div class="product-accordion">
              <div class="accordion-item" onclick="this.classList.toggle('open');this.nextElementSibling.style.display=this.nextElementSibling.style.display==='block'?'none':'block';">
                <span class="accordion-label">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                  Ürün Bilgisi
                </span>
                <span class="accordion-toggle">+</span>
              </div>
              <div class="accordion-content">${product.description}</div>

              <div class="accordion-item" onclick="this.classList.toggle('open');this.nextElementSibling.style.display=this.nextElementSibling.style.display==='block'?'none':'block';">
                <span class="accordion-label">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
                  Bakım Talimatları
                </span>
                <span class="accordion-toggle">+</span>
              </div>
              <div class="accordion-content">30°C'de yıkayın. Tamburlu kurutucu kullanmayın, asarak kurutun. Düşük ısıda ütüleyin. Ağartıcı kullanmayın. Profesyonel kuru temizleme önerilir.</div>

              <div class="accordion-item accordion-item--link" onclick="document.getElementById('sizeGuideModal') && document.getElementById('sizeGuideModal').classList.add('open');">
                <span class="accordion-label">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.3 15.3 8.7 2.7a1 1 0 00-1.4 0L2.7 7.3a1 1 0 000 1.4l12.6 12.6a1 1 0 001.4 0l4.6-4.6a1 1 0 000-1.4z"/><path d="m7.5 10.5 2 2"/><path d="m10.5 7.5 2 2"/><path d="m13.5 4.5 2 2"/><path d="m4.5 13.5 2 2"/></svg>
                  Beden Tablosu
                </span>
                <span class="accordion-toggle">→</span>
              </div>

              <div class="accordion-item" onclick="this.classList.toggle('open');this.nextElementSibling.style.display=this.nextElementSibling.style.display==='block'?'none':'block';">
                <span class="accordion-label">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  Kargo & İade
                </span>
                <span class="accordion-toggle">+</span>
              </div>
              <div class="accordion-content">100€ üzeri siparişlerde kargo ücretsizdir. Standart teslimat 3-5 iş günü. 14 gün içinde ücretsiz değişim ve iade hakkı.</div>
            </div>

            <div class="pdp-payment-strip" aria-label="Kabul edilen ödeme yöntemleri">
              <span class="pdp-payment-badge">VISA</span>
              <span class="pdp-payment-badge">MASTERCARD</span>
              <span class="pdp-payment-badge">TROY</span>
              <span class="pdp-payment-badge">IYZICO</span>
            </div>
          </div>
        </div>

        <section class="pdp-related" aria-labelledby="pdpRelatedHeading">
          <h2 id="pdpRelatedHeading">BENZER ÜRÜNLER</h2>
          <div class="pdp-related-grid">
            ${relatedSlice.length > 0
              ? relatedSlice.map(p => `
                <a href="${B}product?id=${p.id}" class="pdp-related-card">
                  <div class="pdp-related-img">
                    ${(p.images && p.images[0]) ? `<img src="${imgBase}${p.images[0]}" alt="${p.name}" loading="lazy">` : '<div class="pdp-related-img-empty"></div>'}
                    ${p.badge ? `<span class="pdp-related-badge">${p.badge}</span>` : ''}
                  </div>
                  <div class="pdp-related-name">${p.name}</div>
                  <div class="pdp-related-price">€${p.price.toFixed(2)}</div>
                </a>
              `).join('')
              : `<div class="pdp-related-empty">Yakında daha fazla ürün.</div>`
            }
          </div>
        </section>
      `;

      wireInteractions(product);
      wireColorSwatches(product, variantColors, frames360, imgBase);
    }

    function wireColorSwatches(product, variantColors, baseFrames360, imgBase) {
      const swatches = document.querySelectorAll('.pdp-color-swatch');
      if (!swatches.length) return;

      swatches.forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.colorIdx, 10);
          const color = variantColors[idx];
          if (!color) return;

          // 1. active UI state + label
          swatches.forEach(b => b.classList.toggle('active', parseInt(b.dataset.colorIdx, 10) === idx));
          const nameEl = document.getElementById('activeColorName');
          if (nameEl) nameEl.textContent = color.name;

          // 2. gallery / 360 — only rebuild if this color has own images
          const colorHasImages = Array.isArray(color.images) && color.images.length > 0;
          const colorHas360 = Array.isArray(color.images360) && color.images360.length > 0;
          if (colorHasImages || colorHas360) {
            const eImages = colorHasImages ? color.images : (product.images || []);
            const eFrames360 = colorHas360 ? color.images360 : (baseFrames360 || []);
            const eHas360 = eFrames360.length >= 4 && eFrames360.every(f => f && typeof f === 'object' && f.src);
            const eThumbs = eHas360
              ? eFrames360.map((f, i) => ({ src: f.src, label: f.label || ('View ' + (i+1)), flip: !!f.flip }))
              : eImages.map((src, i) => ({ src, label: 'View ' + (i+1), flip: false }));

            const thumbsEl = document.getElementById('pdThumbs');
            if (thumbsEl && eThumbs.length >= 2) {
              thumbsEl.innerHTML = eThumbs.map((t, i) => `
                <button class="pd-thumb${i===0?' active':''}" type="button" data-idx="${i}" aria-label="${t.label}">
                  <img src="${imgBase}${t.src}" alt="${t.label}" style="${t.flip?'transform:scaleX(-1);':''}">
                </button>
              `).join('');
            }

            const stageWrap = document.querySelector('.pd-stage-wrap');
            if (stageWrap) {
              const framesData = eHas360 ? eFrames360 : eImages;
              stageWrap.innerHTML = '<carousel-3d data-frames=\'' + attrJSON(framesData) + '\' data-img-base="' + imgBase + '" data-has360="' + eHas360 + '"></carousel-3d>';
            }

            // Re-attach thumb click handlers — DOM was rebuilt above.
            const newCarousel = document.querySelector('carousel-3d');
            document.querySelectorAll('.pd-thumb').forEach(t => {
              t.addEventListener('click', () => {
                document.querySelectorAll('.pd-thumb').forEach(x => x.classList.remove('active'));
                t.classList.add('active');
                const i = parseInt(t.dataset.idx, 10);
                if (newCarousel && typeof newCarousel.setIdx === 'function') {
                  newCarousel.setIdx(i);
                  newCarousel.setMode('flat');
                }
              });
            });
          }

          // 3. stock indicator (only if color carries its own stock count)
          if (typeof color.stock === 'number') {
            const stockEl = document.querySelector('.pdp-stock');
            if (stockEl) {
              if (color.stock > 0) {
                stockEl.innerHTML = '<span class="pdp-stock-dot" aria-hidden="true"></span><strong>Stokta</strong> <span>— ' + color.stock + ' adet</span>';
              } else {
                stockEl.innerHTML = '<span class="pdp-stock-dot" aria-hidden="true" style="background:#dc3545"></span><strong>Stokta yok</strong>';
              }
            }
          }

          // 4. price override
          const priceEl = document.querySelector('.pd-info > p');
          if (priceEl) {
            const eff = (typeof color.priceOverride === 'number') ? color.priceOverride : product.price;
            priceEl.textContent = '€' + eff.toFixed(2);
          }
        });
      });
    }

    function wireInteractions(product) {
      const logoEls = document.querySelectorAll('.header .logo-text');
      logoEls.forEach(el => el.style.color = product.color);
      // Old .swatch-product hover handlers were tied to the now-removed
      // cross-product swatch row. Cross-product navigation lives in the
      // BENZER ÜRÜNLER section below the fold. Color-swatch click handlers
      // for the new variant row are wired in the next commit.

      const carousel = document.querySelector('carousel-3d');
      const thumbs = document.querySelectorAll('.pd-thumb');

      thumbs.forEach(t => {
        t.addEventListener('click', () => {
          thumbs.forEach(x => x.classList.remove('active'));
          t.classList.add('active');
          const i = parseInt(t.dataset.idx, 10);
          if (carousel && typeof carousel.setIdx === 'function') {
            carousel.setIdx(i);
            carousel.setMode('flat');
          }
        });
      });

      if (carousel) {
        carousel.addEventListener('c3d:idx-change', (e) => {
          const i = e.detail && e.detail.idx;
          if (typeof i !== 'number') return;
          thumbs.forEach((t, n) => t.classList.toggle('active', n === i));
        });
      }

      let selectedSize = null;
      document.querySelectorAll('.size-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.size-btn').forEach(b => { b.style.background = 'transparent'; b.style.color = 'inherit'; });
          btn.style.background = 'rgb(var(--button-background))';
          btn.style.color = 'rgb(var(--button-text-color))';
          selectedSize = btn.dataset.size;
        });
      });

      const addToCart = document.getElementById('addToCartBtn');
      if (addToCart) addToCart.addEventListener('click', () => {
        if (!selectedSize) {
          const section = document.getElementById('sizeSection');
          section.style.outline = '2px solid #c94c4c';
          section.style.outlineOffset = '4px';
          setTimeout(() => { section.style.outline = 'none'; }, 1500);
          return;
        }
        if (window.Cart && typeof window.Cart.add === 'function') window.Cart.add(product, selectedSize);
        const btn = document.getElementById('addToCartBtn');
        btn.textContent = '✓ ADDED'; btn.style.background = '#28a745';
        setTimeout(() => { btn.textContent = 'ADD TO CART'; btn.style.background = 'rgb(var(--button-background))'; }, 2000);
      });
    }

    tryRender();

    // ESC closes the size-guide modal.
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const modal = document.getElementById('sizeGuideModal');
      if (modal && modal.classList.contains('open')) modal.classList.remove('open');
    });
  });
  </script>
</Layout>

<style is:global>
  /* ===== Product page layout =====
     Outer wrapper renamed .pd-page to escape legacy `.product-container { display:grid; 1.2fr 0.8fr }`
     in style.css that hijacked our layout. .pd-gallery / .pd-info renamed for the same reason. */
  .pd-page {
    display: block;
  }
  .product-grid-layout {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: 3rem;
    align-items: start;
  }
  .pd-gallery {
    display: grid;
    grid-template-columns: 80px minmax(0, 1fr);
    gap: 1rem;
    position: sticky;
    top: 6rem;
  }
  .pd-gallery-no-thumbs {
    grid-template-columns: minmax(0, 1fr);
  }
  .pd-info {
    position: static;
  }

  /* ===== Color swatches (variant) ===== */
  .pdp-color-swatches {
    margin-bottom: 1.25rem;
  }
  .pdp-color-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgb(var(--text-color) / 0.5);
    display: block;
    margin-bottom: 0.5rem;
  }
  .pdp-color-label strong {
    color: rgb(var(--text-color));
    font-weight: 700;
  }
  .swatch-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .pdp-color-swatch {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid transparent;
    background: none;
    padding: 2px;
    cursor: pointer;
    position: relative;
    transition: border-color 0.15s;
  }
  .pdp-color-swatch.active { border-color: rgb(var(--text-color)); }
  .pdp-color-swatch:hover { border-color: rgb(var(--text-color) / 0.5); }
  .pdp-color-swatch.active:hover { border-color: rgb(var(--text-color)); }
