---
import Layout from '../layouts/Layout.astro';
const base = (import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/');
---
<Layout title="Product — Over2You" description="Over2You — premium temel parçalar.">
  <div class="pd-page" style="padding:6rem var(--container-gutter) 4rem;max-width:1400px;margin:0 auto;">
    <div class="product-layout" id="productLayout">
      <p style="text-align:center;padding:4rem;color:rgb(var(--text-color)/0.4);">Loading product...</p>
    </div>
  </div>

  <!-- Size guide modal — outside #productLayout so render() doesn't wipe it.
       Triggered by the accordion's "Beden Tablosu" item (which calls
       this.classList.add('open')). -->
  <div id="sizeGuideModal" class="size-guide-modal" onclick="if(event.target===this) this.classList.remove('open');" role="dialog" aria-labelledby="sizeGuideTitle" aria-modal="true">
    <div class="size-guide-modal-inner">
      <button class="size-guide-modal-close" type="button" onclick="document.getElementById('sizeGuideModal').classList.remove('open');" aria-label="Kapat">×</button>
      <h2 id="sizeGuideTitle">BEDEN TABLOSU</h2>
      <p class="size-guide-intro">Vücut ölçülerinize göre seçim önerisi. Ürün ölçüleri parça başına değişebilir; sıkı/oversize tercih ediyorsanız bir alt/üst beden seçebilirsiniz.</p>
      <div class="size-guide-table-wrap">
        <table class="size-guide-table">
          <thead>
            <tr>
              <th>Beden</th>
              <th>Göğüs (cm)</th>
              <th>Bel (cm)</th>
              <th>Kalça (cm)</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>XS</td><td>82–86</td><td>62–66</td><td>88–92</td></tr>
            <tr><td>S</td><td>86–90</td><td>66–70</td><td>92–96</td></tr>
            <tr><td>M</td><td>90–96</td><td>70–76</td><td>96–102</td></tr>
            <tr><td>L</td><td>96–102</td><td>76–82</td><td>102–108</td></tr>
            <tr><td>XL</td><td>102–108</td><td>82–88</td><td>108–114</td></tr>
            <tr><td>XXL</td><td>108–114</td><td>88–94</td><td>114–120</td></tr>
          </tbody>
        </table>
      </div>
      <p class="size-guide-note">Müşteri-onaylı ürün-bazlı ölçüler eklenince bu tablo güncellenecek (genel referans).</p>
    </div>
  </div>

  <!-- Fullscreen image lightbox — opens on main stage click. Sibling of
       #productLayout so render() doesn't wipe it. -->
  <div id="pdpLightbox" class="pdp-lightbox" hidden role="dialog" aria-modal="true" aria-label="Ürün görseli büyütme">
    <button class="lightbox-close" type="button" aria-label="Kapat">×</button>
    <button class="lightbox-prev" type="button" aria-label="Önceki">‹</button>
    <img class="lightbox-img" src="" alt="" />
    <button class="lightbox-next" type="button" aria-label="Sonraki">›</button>
    <div class="lightbox-counter" aria-live="polite"></div>
  </div>

  <script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const MAX_WAIT_MS = 4000;
    const POLL_MS = 80;
    const started = Date.now();

    const tryRender = () => {
      if (!window.productsReady) {
        if (Date.now() - started > MAX_WAIT_MS) { render(); return; }
        setTimeout(tryRender, POLL_MS);
        return;
      }
      render();
    };

    function attrJSON(obj) {
      return JSON.stringify(obj)
        .replace(/&/g, '&amp;')
        .replace(/'/g, '&#39;');
    }

    function render() {
      const params = new URLSearchParams(window.location.search);
      const id = parseInt(params.get('id'));
      const list = (window.products && window.products.length) ? window.products : [];
      const product = list.find(p => p.id === id);
      const layout = document.getElementById('productLayout');

      if (!product) {
        layout.innerHTML = '<div style="text-align:center;padding:4rem;"><h2 style="font:var(--heading-font-style) 800 1.5rem/1.2 var(--heading-font-family);margin-bottom:1rem;">Product Not Found</h2><a href="' + window.O2Y_BASE + 'shop" class="btn-primary" style="display:inline-block;padding:0.75rem 2rem;">BACK TO SHOP</a></div>';
        return;
      }

      // SEO: prefer product.seo.metaTitle / metaDescription, fall back to defaults
      document.title = (product.seo && product.seo.metaTitle) || (product.name + ' — Over2You');
      const metaDesc = (product.seo && product.seo.metaDescription) || (product.description || '').slice(0, 160);
      let metaEl = document.querySelector('meta[name="description"]');
      if (!metaEl) { metaEl = document.createElement('meta'); metaEl.setAttribute('name', 'description'); document.head.appendChild(metaEl); }
      metaEl.setAttribute('content', metaDesc);
      const B = window.O2Y_BASE;
      const imgBase = B + 'img/';
      const related = list.filter(r => r.category === product.category && r.id !== product.id).slice(0, 8);

      const frames360 = Array.isArray(product.images360) ? product.images360 : [];
      const has360 = frames360.length >= 4 && frames360.every(f => f && typeof f === 'object' && f.src);

      // Related products for below-fold section: max 4 from other products,
      // shuffled so repeat visits feel fresh. Single-product fallback handled
      // in the section template.
      const otherProducts = list.filter(p => p.id !== product.id);
      const shuffled = otherProducts.slice().sort(() => Math.random() - 0.5);
      const relatedSlice = shuffled.slice(0, 4);

      // Variant colors. New schema: product.colors[] — each entry has
      // {id, name, hex, default} + optional advanced fields (images,
      // images360, stock, priceOverride). Legacy products without colors[]
      // get a synthesized 1-entry array from the top-level color/colorName.
      const variantColors = (Array.isArray(product.colors) && product.colors.length > 0)
        ? product.colors
        : [{ id: 'default', name: product.colorName || '—', hex: product.color || '#000000', default: true }];
      const defaultColorIdx = Math.max(0, variantColors.findIndex(c => c.default));
      const defaultColor = variantColors[defaultColorIdx] || variantColors[0];

      const framesData = has360
        ? frames360
        : (Array.isArray(product.images) ? product.images : []);

      const thumbsSource = has360
        ? frames360.map((f, i) => ({ src: f.src, label: f.label || ('View ' + (i+1)), flip: !!f.flip }))
        : (product.images || []).map((src, i) => ({ src, label: 'View ' + (i+1), flip: false }));

      const N = thumbsSource.length;
      const showThumbs = N >= 2;

      const thumbsHTML = showThumbs ? thumbsSource.map((t, i) => `
        <button class="pd-thumb${i === 0 ? ' active' : ''}" type="button" data-idx="${i}" aria-label="${t.label}">
          <img src="${imgBase}${t.src}" alt="${t.label}" style="${t.flip ? 'transform:scaleX(-1);' : ''}">
        </button>
      `).join('') : '';

      const stageHTML =
        `<carousel-3d data-frames='${attrJSON(framesData)}' data-img-base="${imgBase}" data-has360="${has360}"></carousel-3d>`;

      layout.innerHTML = `
        <div class="product-breadcrumb" style="font-size:11px;color:rgb(var(--text-color)/0.4);margin-bottom:1.5rem;">
          <a href="${B}" style="color:inherit;">Home</a> /
          <a href="${B}shop?cat=${product.category}" style="color:inherit;">${product.category.charAt(0).toUpperCase()+product.category.slice(1)}</a> /
          <span style="color:rgb(var(--text-color)/0.7);">${product.name}</span>
        </div>
        <div class="product-grid-layout">
          <div class="pd-gallery${showThumbs ? '' : ' pd-gallery-no-thumbs'}">
            ${showThumbs ? `<div class="pd-thumbs" id="pdThumbs">${thumbsHTML}</div>` : ''}
            <div class="pd-stage-wrap">${stageHTML}<div class="magnify-lens" hidden aria-hidden="true"></div></div>
          </div>
          <div class="pd-info">
            <h1 style="font:var(--heading-font-style) 800 1.5rem/1.2 var(--heading-font-family);text-transform:uppercase;letter-spacing:0.03em;margin-bottom:0.75rem;">${product.name}</h1>
            ${product.sku ? `<p style="font-size:11px;color:rgb(var(--text-color)/0.45);letter-spacing:0.04em;margin-bottom:0.6rem;">SKU: ${product.sku}</p>` : ''}
            ${(() => {
              const onSale = typeof product.salePrice === 'number' && product.salePrice < product.price;
              const eff = onSale ? product.salePrice : product.price;
              return onSale
                ? `<p style="font-size:var(--text-base);margin-bottom:1rem;"><strong style="color:#c94c4c;">₺${eff.toFixed(2)}</strong> <del style="color:rgb(var(--text-color)/0.5);font-weight:400;margin-left:0.4em;">₺${product.price.toFixed(2)}</del></p>`
                : `<p style="font-size:var(--text-base);margin-bottom:1rem;">₺${eff.toFixed(2)}</p>`;
            })()}
            ${(() => {
              const onSale = typeof product.salePrice === 'number' && product.salePrice < product.price;
              const badge = onSale ? 'SALE' : (product.badge || '');
              return badge ? `<span style="display:inline-block;padding:3px 8px;font-size:10px;font-weight:700;background:rgb(var(--text-color));color:rgb(var(--background));margin-bottom:1.25rem;">${badge}</span>` : '';
            })()}

            <div class="pdp-color-swatches">
              <span class="pdp-color-label"><span data-i18n="pdp.color">RENK:</span> <strong id="activeColorName">${defaultColor.name}</strong></span>
              <div class="swatch-row">
                ${variantColors.map((c, idx) => `
                  <button type="button" class="pdp-color-swatch${idx === defaultColorIdx ? ' active' : ''}" data-color-idx="${idx}" data-color-id="${c.id}" aria-label="${c.name}" title="${c.name}">
                    <span class="swatch-circle" style="background:${c.hex};"></span>
                    ${(Array.isArray(c.images) && c.images.length > 0) ? `<span class="swatch-thumb" style="background-image:url(${imgBase}${c.images[0]});"></span>` : ''}
                  </button>
                `).join('')}
              </div>
            </div>

            <div style="margin-bottom:1.25rem;" id="sizeSection">
              <span data-i18n="pdp.size" style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:rgb(var(--text-color)/0.5);display:block;margin-bottom:0.5rem;">BEDEN:</span>
              <div style="display:flex;gap:6px;flex-wrap:wrap;" id="sizeButtons">
                ${product.sizes.map(s => `<button class="size-btn" data-size="${s}" style="padding:0.5rem 1rem;border:1px solid rgb(var(--border-color));background:transparent;font:var(--heading-font-style) 600 11px/1 var(--heading-font-family);cursor:pointer;transition:all 0.2s;">${s}</button>`).join('')}
              </div>
            </div>

            ${product.outOfStock
              ? `<div class="pdp-stock pdp-stock--oos">
                  <span class="pdp-stock-dot" aria-hidden="true" style="background:#dc3545"></span>
                  <strong>Stokta Yok</strong> <span>— stok yenilendiğinde haber veririz</span>
                </div>`
              : `<div class="pdp-stock">
                  <span class="pdp-stock-dot" aria-hidden="true"></span>
                  <strong>Stokta</strong> <span>— ${(typeof product.stockQty === 'number' && product.stockQty > 0 && product.stockQty < 10) ? `son ${product.stockQty} adet` : '3-5 iş günü içinde kargoda'}</span>
                </div>`
            }

            <button id="addToCartBtn" ${product.outOfStock ? 'disabled' : ''} style="width:100%;padding:1rem;background:${product.outOfStock ? 'rgb(var(--text-color)/0.2)' : 'rgb(var(--button-background))'};color:${product.outOfStock ? 'rgb(var(--text-color)/0.5)' : 'rgb(var(--button-text-color))'};border:none;font:var(--heading-font-style) 800 var(--text-sm)/1.65 var(--heading-font-family);text-transform:uppercase;letter-spacing:0.03em;cursor:${product.outOfStock ? 'not-allowed' : 'pointer'};transition:all 0.3s;margin-bottom:0.85rem;">${product.outOfStock ? 'STOKTA YOK' : 'ADD TO CART'}</button>

            <div class="pdp-banner">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="23 4 23 10 17 10"/>
                <polyline points="1 20 1 14 7 14"/>
                <path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/>
              </svg>
              <span data-i18n="pdp.freeReturn">14 gün ücretsiz değişim hakkı</span>
            </div>

            <div class="product-accordion">
              <div class="accordion-item" onclick="this.classList.toggle('open');this.nextElementSibling.style.display=this.nextElementSibling.style.display==='block'?'none':'block';">
                <span class="accordion-label">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                  <span data-i18n="pdp.accordion.info">Ürün Bilgisi</span>
                </span>
                <span class="accordion-toggle">+</span>
              </div>
              <div class="accordion-content">${product.description}</div>

              <div class="accordion-item" onclick="this.classList.toggle('open');this.nextElementSibling.style.display=this.nextElementSibling.style.display==='block'?'none':'block';">
                <span class="accordion-label">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
                  <span data-i18n="pdp.accordion.care">Bakım Talimatları</span>
                </span>
                <span class="accordion-toggle">+</span>
              </div>
              <div class="accordion-content">30°C'de yıkayın. Tamburlu kurutucu kullanmayın, asarak kurutun. Düşük ısıda ütüleyin. Ağartıcı kullanmayın. Profesyonel kuru temizleme önerilir.</div>

              <div class="accordion-item accordion-item--link" onclick="document.getElementById('sizeGuideModal') && document.getElementById('sizeGuideModal').classList.add('open');">
                <span class="accordion-label">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.3 15.3 8.7 2.7a1 1 0 00-1.4 0L2.7 7.3a1 1 0 000 1.4l12.6 12.6a1 1 0 001.4 0l4.6-4.6a1 1 0 000-1.4z"/><path d="m7.5 10.5 2 2"/><path d="m10.5 7.5 2 2"/><path d="m13.5 4.5 2 2"/><path d="m4.5 13.5 2 2"/></svg>
                  <span data-i18n="pdp.accordion.size">Beden Tablosu</span>
                </span>
                <span class="accordion-toggle">→</span>
              </div>

              <div class="accordion-item" onclick="this.classList.toggle('open');this.nextElementSibling.style.display=this.nextElementSibling.style.display==='block'?'none':'block';">
                <span class="accordion-label">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  <span data-i18n="pdp.accordion.shipping">Kargo & İade</span>
                </span>
                <span class="accordion-toggle">+</span>
              </div>
              <div class="accordion-content">100₺ üzeri siparişlerde kargo ücretsizdir. Standart teslimat 3-5 iş günü. 14 gün içinde ücretsiz değişim ve iade hakkı.</div>
            </div>

            <div class="pdp-payment-strip" aria-label="Kabul edilen ödeme yöntemleri">
              <span class="pdp-payment-badge">VISA</span>
              <span class="pdp-payment-badge">MASTERCARD</span>
              <span class="pdp-payment-badge">TROY</span>
              <span class="pdp-payment-badge">IYZICO</span>
            </div>
          </div>
        </div>

        <section class="pdp-related" aria-labelledby="pdpRelatedHeading">
          <h2 id="pdpRelatedHeading" data-i18n="pdp.related.heading">BENZER ÜRÜNLER</h2>
          <div class="pdp-related-grid">
            ${relatedSlice.length > 0
              ? relatedSlice.map(p => `
                <a href="${B}product?id=${p.id}" class="pdp-related-card">
                  <div class="pdp-related-img">
                    ${(p.images && p.images[0]) ? `<img src="${imgBase}${p.images[0]}" alt="${p.name}" loading="lazy">` : '<div class="pdp-related-img-empty"></div>'}
                    ${p.badge ? `<span class="pdp-related-badge">${p.badge}</span>` : ''}
                  </div>
                  <div class="pdp-related-name">${p.name}</div>
                  <div class="pdp-related-price">₺${(typeof p.salePrice === 'number' && p.salePrice < p.price ? p.salePrice : p.price).toFixed(2)}</div>
                </a>
              `).join('')
              : `<div class="pdp-related-empty" data-i18n="pdp.related.empty">Yakında daha fazla ürün.</div>`
            }
          </div>
        </section>

        <section class="pdp-bundle" id="pdpBundle" aria-labelledby="pdpBundleHeading" hidden>
          <h2 id="pdpBundleHeading" data-i18n="pdp.bundle.title">Bu Ürünle Tamamla</h2>
          <p class="pdp-bundle-pitch" data-i18n="pdp.bundle.pitch">Aynı estetiği paylaşan parçalar.</p>
          <div class="pdp-bundle-grid"></div>
          <div class="pdp-bundle-cta">
            <button type="button" class="pdp-bundle-add" id="bundleAddAll"><span data-i18n="pdp.bundle.addAll">Tümünü Sepete Ekle</span></button>
            <span class="pdp-bundle-total"><span data-i18n="pdp.bundle.total">Toplam</span>: ₺<span id="bundleTotal">0.00</span></span>
          </div>
        </section>
      `;

      wireInteractions(product);
      wireColorSwatches(product, variantColors, frames360, imgBase);
      wireLightbox(thumbsSource, imgBase);
      wireBundle(product, list, imgBase);
      wireMagnify();
      // Re-apply translations to the dynamically rendered PDP DOM.
      if (typeof window.o2yApplyLang === 'function') {
        window.o2yApplyLang(window.o2yLang || 'tr');
      }
    }

    function wireColorSwatches(product, variantColors, baseFrames360, imgBase) {
      const swatches = document.querySelectorAll('.pdp-color-swatch');
      if (!swatches.length) return;

      swatches.forEach(btn => {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.colorIdx, 10);
          const color = variantColors[idx];
          if (!color) return;

          // 1. active UI state + label
          swatches.forEach(b => b.classList.toggle('active', parseInt(b.dataset.colorIdx, 10) === idx));
          const nameEl = document.getElementById('activeColorName');
          if (nameEl) nameEl.textContent = color.name;

          // 2. gallery / 360 — compute effective thumbs (used by both DOM
          //    rebuild and lightbox sync below).
          const colorHasImages = Array.isArray(color.images) && color.images.length > 0;
          const colorHas360 = Array.isArray(color.images360) && color.images360.length > 0;
          const eImages = colorHasImages ? color.images : (product.images || []);
          const eFrames360 = colorHas360 ? color.images360 : (baseFrames360 || []);
          const eHas360 = eFrames360.length >= 4 && eFrames360.every(f => f && typeof f === 'object' && f.src);
          const eThumbs = eHas360
            ? eFrames360.map((f, i) => ({ src: f.src, label: f.label || ('View ' + (i+1)), flip: !!f.flip }))
            : eImages.map((src, i) => ({ src, label: 'View ' + (i+1), flip: false }));
          // Sync lightbox so it always reflects the active color's images.
          if (window.__pdpLightboxSet) window.__pdpLightboxSet(eThumbs, imgBase);
          if (colorHasImages || colorHas360) {
            const thumbsEl = document.getElementById('pdThumbs');
            if (thumbsEl && eThumbs.length >= 2) {
              thumbsEl.innerHTML = eThumbs.map((t, i) => `
                <button class="pd-thumb${i===0?' active':''}" type="button" data-idx="${i}" aria-label="${t.label}">
                  <img src="${imgBase}${t.src}" alt="${t.label}" style="${t.flip?'transform:scaleX(-1);':''}">
                </button>
              `).join('');
            }

            const stageWrap = document.querySelector('.pd-stage-wrap');
            if (stageWrap) {
              const framesData = eHas360 ? eFrames360 : eImages;
              stageWrap.innerHTML = '<carousel-3d data-frames=\'' + attrJSON(framesData) + '\' data-img-base="' + imgBase + '" data-has360="' + eHas360 + '"></carousel-3d>';
            }

            // Re-attach thumb click handlers — DOM was rebuilt above.
            const newCarousel = document.querySelector('carousel-3d');
            document.querySelectorAll('.pd-thumb').forEach(t => {
              t.addEventListener('click', () => {
                document.querySelectorAll('.pd-thumb').forEach(x => x.classList.remove('active'));
                t.classList.add('active');
                const i = parseInt(t.dataset.idx, 10);
                if (newCarousel && typeof newCarousel.setIdx === 'function') {
                  newCarousel.setIdx(i);
                  newCarousel.setMode('flat');
                }
              });
            });
          }

          // 3. stock indicator (only if color carries its own stock count)
          if (typeof color.stock === 'number') {
            const stockEl = document.querySelector('.pdp-stock');
            if (stockEl) {
              if (color.stock > 0) {
                stockEl.innerHTML = '<span class="pdp-stock-dot" aria-hidden="true"></span><strong>Stokta</strong> <span>— ' + color.stock + ' adet</span>';
              } else {
                stockEl.innerHTML = '<span class="pdp-stock-dot" aria-hidden="true" style="background:#dc3545"></span><strong>Stokta yok</strong>';
              }
            }
          }

          // 4. price override / sale aware
          const priceEl = document.querySelector('.pd-info > p');
          if (priceEl) {
            const onSale = typeof product.salePrice === 'number' && product.salePrice < product.price;
            const baseEff = onSale ? product.salePrice : product.price;
            const eff = (typeof color.priceOverride === 'number') ? color.priceOverride : baseEff;
            if (onSale && typeof color.priceOverride !== 'number') {
              priceEl.innerHTML = '<strong style="color:#c94c4c;">₺' + eff.toFixed(2) + '</strong> <del style="color:rgb(var(--text-color)/0.5);font-weight:400;margin-left:0.4em;">₺' + product.price.toFixed(2) + '</del>';
            } else {
              priceEl.textContent = '₺' + eff.toFixed(2);
            }
          }

          // 5. header logo color — match selected variant
          document.querySelectorAll('.header .logo-text').forEach(el => {
            el.style.color = color.hex;
          });

          // 6. own-images yok hint — pill on stage when fallback path used
          const stageHost = document.querySelector('.pd-stage-wrap');
          if (stageHost) {
            let hint = stageHost.querySelector('.pdp-color-hint');
            if (!hint) {
              hint = document.createElement('div');
              hint.className = 'pdp-color-hint';
              stageHost.appendChild(hint);
            }
            if (!colorHasImages && !color.default) {
              hint.textContent = color.name.toLowerCase() + ' için fotoğraflar yakında';
              hint.classList.add('visible');
            } else {
              hint.classList.remove('visible');
            }
          }
        });
      });
    }

    function wireLightbox(initialThumbs, imgBase) {
      const lb = document.getElementById('pdpLightbox');
      if (!lb) return;
      const img = lb.querySelector('.lightbox-img');
      const counter = lb.querySelector('.lightbox-counter');
      const prevBtn = lb.querySelector('.lightbox-prev');
      const nextBtn = lb.querySelector('.lightbox-next');
      const closeBtn = lb.querySelector('.lightbox-close');

      let thumbs = (initialThumbs || []).slice();
      let base = imgBase;
      let idx = 0;
      let isOpen = false;
      let pinchScale = 1;

      function resetZoom() {
        pinchScale = 1;
        img.style.transform = '';
      }

      function update() {
        const t = thumbs[idx];
        if (!t) return;
        img.src = base + t.src;
        img.alt = t.label || '';
        // base flip preserves; pinch reset on image change.
        resetZoom();
        if (t.flip) img.style.transform = 'scaleX(-1)';
        const single = thumbs.length <= 1;
        if (counter) counter.textContent = thumbs.length > 0 ? (idx + 1) + ' / ' + thumbs.length : '';
        prevBtn.style.visibility = (single || idx === 0) ? 'hidden' : 'visible';
        nextBtn.style.visibility = (single || idx === thumbs.length - 1) ? 'hidden' : 'visible';
      }

      function open(at) {
        if (!thumbs.length) return;
        idx = Math.max(0, Math.min(thumbs.length - 1, at || 0));
        update();
        lb.removeAttribute('hidden');
        document.body.style.overflow = 'hidden';
        isOpen = true;
      }
      function close() {
        lb.setAttribute('hidden', '');
        document.body.style.overflow = '';
        isOpen = false;
        resetZoom();
      }

      // Pinch-to-zoom (mobile) + double-tap reset.
      let startDist = 0;
      let startScale = 1;
      let lastTap = 0;
      function dist(touches) {
        return Math.hypot(touches[0].clientX - touches[1].clientX, touches[0].clientY - touches[1].clientY);
      }
      img.addEventListener('touchstart', (e) => {
        if (e.touches.length === 2) {
          startDist = dist(e.touches);
          startScale = pinchScale;
        }
      }, { passive: true });
      img.addEventListener('touchmove', (e) => {
        if (e.touches.length === 2 && startDist > 0) {
          e.preventDefault();
          const ratio = dist(e.touches) / startDist;
          pinchScale = Math.max(1, Math.min(4, startScale * ratio));
          const flip = thumbs[idx] && thumbs[idx].flip ? 'scaleX(-1)' : '';
          img.style.transform = (flip ? flip + ' ' : '') + 'scale(' + pinchScale + ')';
        }
      }, { passive: false });
      img.addEventListener('touchend', (e) => {
        if (e.touches.length < 2) startDist = 0;
        // Double-tap reset.
        if (e.changedTouches.length === 1 && e.touches.length === 0) {
          const now = Date.now();
          if (now - lastTap < 300 && pinchScale > 1) resetZoom();
          lastTap = now;
        }
      });

      prevBtn.addEventListener('click', () => { if (idx > 0) { idx--; update(); } });
      nextBtn.addEventListener('click', () => { if (idx < thumbs.length - 1) { idx++; update(); } });
      closeBtn.addEventListener('click', close);
      lb.addEventListener('click', (e) => { if (e.target === lb) close(); });

      document.addEventListener('keydown', (e) => {
        if (!isOpen) return;
        if (e.key === 'Escape') { e.preventDefault(); close(); }
        else if (e.key === 'ArrowLeft' && idx > 0) { e.preventDefault(); idx--; update(); }
        else if (e.key === 'ArrowRight' && idx < thumbs.length - 1) { e.preventDefault(); idx++; update(); }
      });

      // Click on the flat-mode main image (.c3d-flat inside carousel-3d) opens
      // the lightbox at the carousel's current idx. Delegated on .pd-stage-wrap
      // so re-rendered carousel-3d (color switch) still works.
      const stageWrap = document.querySelector('.pd-stage-wrap');
      if (stageWrap) {
        stageWrap.addEventListener('click', (e) => {
          if (!e.target.closest('.c3d-flat')) return;
          const carousel = document.querySelector('carousel-3d');
          const at = (carousel && typeof carousel.idx === 'number') ? carousel.idx : 0;
          open(at);
        });
      }

      // Color switch updates this state via window.__pdpLightboxSet.
      window.__pdpLightboxSet = (newThumbs, newBase) => {
        thumbs = (newThumbs || []).slice();
        if (newBase) base = newBase;
        if (isOpen) {
          idx = Math.min(idx, Math.max(0, thumbs.length - 1));
          update();
        }
      };
    }

    function wireMagnify() {
      // Desktop hover magnify lens — disabled on touch / small viewports.
      if (window.matchMedia('(max-width: 768px), (hover: none)').matches) return;
      const wrap = document.querySelector('.pd-stage-wrap');
      const lens = wrap && wrap.querySelector('.magnify-lens');
      if (!wrap || !lens) return;

      const LENS = 220;
      const ZOOM = 2;

      function getCurrentImg() {
        return wrap.querySelector('.c3d-flat img');
      }

      wrap.addEventListener('mouseenter', () => {
        const img = getCurrentImg();
        if (!img || !img.src) return;
        lens.style.backgroundImage = `url("${img.src}")`;
        lens.style.backgroundSize = (img.clientWidth * ZOOM) + 'px ' + (img.clientHeight * ZOOM) + 'px';
        lens.removeAttribute('hidden');
      });

      wrap.addEventListener('mouseleave', () => {
        lens.setAttribute('hidden', '');
      });

      wrap.addEventListener('mousemove', (e) => {
        if (lens.hasAttribute('hidden')) return;
        const img = getCurrentImg();
        if (!img) return;
        const imgRect = img.getBoundingClientRect();
        // If cursor leaves the image area (carousel padding), hide lens.
        if (e.clientX < imgRect.left || e.clientX > imgRect.right ||
            e.clientY < imgRect.top  || e.clientY > imgRect.bottom) {
          lens.setAttribute('hidden', '');
          return;
        }
        const wrapRect = wrap.getBoundingClientRect();
        const lx = e.clientX - wrapRect.left - LENS / 2;
        const ly = e.clientY - wrapRect.top - LENS / 2;
        lens.style.left = lx + 'px';
        lens.style.top  = ly + 'px';
        // bg position — center the zoomed point under the cursor.
        const px = e.clientX - imgRect.left;
        const py = e.clientY - imgRect.top;
        lens.style.backgroundPosition =
          (-(px * ZOOM - LENS / 2)) + 'px ' + (-(py * ZOOM - LENS / 2)) + 'px';
      });
    }

    function effectivePrice(p) {
      return (typeof p.salePrice === 'number' && p.salePrice < p.price) ? p.salePrice : p.price;
    }

    function wireBundle(product, allProducts, imgBase) {
      const section = document.getElementById('pdpBundle');
      if (!section) return;
      const ids = Array.isArray(product.bundleWith) ? product.bundleWith : [];
      if (ids.length === 0) return;
      const items = allProducts.filter(p => ids.includes(p.id) && p.id !== product.id && !p.deletedAt);
      if (items.length === 0) return;

      const grid = section.querySelector('.pdp-bundle-grid');
      const totalEl = section.querySelector('#bundleTotal');
      const addAll = section.querySelector('#bundleAddAll');

      const B = window.O2Y_BASE;
      const baseTotal = effectivePrice(product);

      grid.innerHTML = items.map(p => {
        const eff = effectivePrice(p);
        const onSale = typeof p.salePrice === 'number' && p.salePrice < p.price;
        const thumb = (p.images && p.images[0])
          ? `<img src="${imgBase}${p.images[0]}" alt="${p.name}" loading="lazy">`
          : '<div class="pdp-bundle-img-empty"></div>';
        return `
          <label class="pdp-bundle-card" data-id="${p.id}" data-price="${eff}">
            <input type="checkbox" class="pdp-bundle-check" checked>
            <a href="${B}product?id=${p.id}" class="pdp-bundle-thumb" aria-label="${p.name}">${thumb}</a>
            <div class="pdp-bundle-meta">
              <div class="pdp-bundle-name">${p.name}</div>
              <div class="pdp-bundle-price">${onSale
                ? '<strong style="color:#c94c4c;">₺' + eff.toFixed(2) + '</strong> <del style="opacity:0.5;">₺' + p.price.toFixed(2) + '</del>'
                : '₺' + eff.toFixed(2)}</div>
            </div>
          </label>
        `;
      }).join('');

      function recalcTotal() {
        let sum = baseTotal;
        section.querySelectorAll('.pdp-bundle-card').forEach(card => {
          const cb = card.querySelector('.pdp-bundle-check');
          if (cb && cb.checked) sum += parseFloat(card.dataset.price) || 0;
        });
        totalEl.textContent = sum.toFixed(2);
      }
      recalcTotal();

      section.querySelectorAll('.pdp-bundle-check').forEach(cb => {
        cb.addEventListener('change', recalcTotal);
      });

      addAll.addEventListener('click', () => {
        if (!window.Cart || typeof window.Cart.add !== 'function') return;
        // Resolve main product's active color from the swatch state.
        const mainColors = (Array.isArray(product.colors) && product.colors.length > 0)
          ? product.colors
          : [{ id: 'default', name: product.colorName || '', hex: product.color || '', default: true }];
        const activeSwatch = document.querySelector('.pdp-color-swatch.active');
        const aci = activeSwatch ? parseInt(activeSwatch.dataset.colorIdx, 10) : -1;
        const mainActiveColor = (aci >= 0 && mainColors[aci]) ? mainColors[aci] : (mainColors.find(c => c.default) || mainColors[0]);
        // Add the current product first if a size is selected (best effort).
        const sizeBtn = document.querySelector('.size-btn[style*="background"]');
        if (sizeBtn) window.Cart.add(product, sizeBtn.dataset.size, mainActiveColor);
        // Then each checked bundle item — fall through to its own default color.
        section.querySelectorAll('.pdp-bundle-card').forEach(card => {
          const cb = card.querySelector('.pdp-bundle-check');
          if (!cb || !cb.checked) return;
          const id = parseInt(card.dataset.id, 10);
          const item = items.find(p => p.id === id);
          if (item) window.Cart.add(item);
        });
      });

      section.removeAttribute('hidden');
    }

    function wireInteractions(product) {
      const logoEls = document.querySelectorAll('.header .logo-text');
      logoEls.forEach(el => el.style.color = product.color);
      // Old .swatch-product hover handlers were tied to the now-removed
      // cross-product swatch row. Cross-product navigation lives in the
      // BENZER ÜRÜNLER section below the fold. Color-swatch click handlers
      // for the new variant row are wired in the next commit.

      const carousel = document.querySelector('carousel-3d');
      const thumbs = document.querySelectorAll('.pd-thumb');

      thumbs.forEach(t => {
        t.addEventListener('click', () => {
          thumbs.forEach(x => x.classList.remove('active'));
          t.classList.add('active');
          const i = parseInt(t.dataset.idx, 10);
          if (carousel && typeof carousel.setIdx === 'function') {
            carousel.setIdx(i);
            carousel.setMode('flat');
          }
        });
      });

      if (carousel) {
        carousel.addEventListener('c3d:idx-change', (e) => {
          const i = e.detail && e.detail.idx;
          if (typeof i !== 'number') return;
          thumbs.forEach((t, n) => t.classList.toggle('active', n === i));
        });
      }

      let selectedSize = null;
      document.querySelectorAll('.size-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.size-btn').forEach(b => { b.style.background = 'transparent'; b.style.color = 'inherit'; });
          btn.style.background = 'rgb(var(--button-background))';
          btn.style.color = 'rgb(var(--button-text-color))';
          selectedSize = btn.dataset.size;
        });
      });

      const addToCart = document.getElementById('addToCartBtn');
      if (addToCart) addToCart.addEventListener('click', () => {
        if (!selectedSize) {
          const section = document.getElementById('sizeSection');
          section.style.outline = '2px solid #c94c4c';
          section.style.outlineOffset = '4px';
          setTimeout(() => { section.style.outline = 'none'; }, 1500);
          return;
        }
        if (window.Cart && typeof window.Cart.add === 'function') {
          // Read the active swatch from the DOM — single source of truth
          // (color switch handler keeps .pdp-color-swatch.active in sync).
          const colorList = (Array.isArray(product.colors) && product.colors.length > 0)
            ? product.colors
            : [{ id: 'default', name: product.colorName || '', hex: product.color || '', default: true }];
          const activeSwatch = document.querySelector('.pdp-color-swatch.active');
          const ci = activeSwatch ? parseInt(activeSwatch.dataset.colorIdx, 10) : -1;
          const activeColor = (ci >= 0 && colorList[ci]) ? colorList[ci] : (colorList.find(c => c.default) || colorList[0]);
          window.Cart.add(product, selectedSize, activeColor);
        }
        const btn = document.getElementById('addToCartBtn');
        btn.textContent = '✓ ADDED'; btn.style.background = '#28a745';
        setTimeout(() => { btn.textContent = 'ADD TO CART'; btn.style.background = 'rgb(var(--button-background))'; }, 2000);
      });
    }

    tryRender();

    // ESC closes the size-guide modal.
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      const modal = document.getElementById('sizeGuideModal');
      if (modal && modal.classList.contains('open')) modal.classList.remove('open');
    });
  });
  </script>
</Layout>

<style is:global>
  /* ===== Product page layout =====
     Outer wrapper renamed .pd-page to escape legacy `.product-container { display:grid; 1.2fr 0.8fr }`
     in style.css that hijacked our layout. .pd-gallery / .pd-info renamed for the same reason. */
  .pd-page {
    display: block;
  }
  .product-grid-layout {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: 3rem;
    align-items: start;
  }
  .pd-gallery {
    display: grid;
    grid-template-columns: 80px minmax(0, 1fr);
    gap: 1rem;
    position: sticky;
    top: 6rem;
  }
  .pd-gallery-no-thumbs {
    grid-template-columns: minmax(0, 1fr);
  }
  .pd-info {
    position: static;
  }

  /* ===== Color swatches (variant) ===== */
  .pdp-color-swatches {
    margin-bottom: 1.25rem;
  }
  .pdp-color-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgb(var(--text-color) / 0.5);
    display: block;
    margin-bottom: 0.5rem;
  }
  .pdp-color-label strong {
    color: rgb(var(--text-color));
    font-weight: 700;
  }
  .swatch-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .pdp-color-swatch {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid transparent;
    background: none;
    padding: 2px;
    cursor: pointer;
    position: relative;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }
  /* Active: scale + double-ring (background gap + text-color halo).
     Border kept transparent so the rings carry the visual weight cleanly. */
  .pdp-color-swatch.active {
    transform: scale(1.08);
    box-shadow:
      0 0 0 2px rgb(var(--background)),
      0 0 0 4px rgb(var(--text-color));
  }
  .pdp-color-swatch:hover:not(.active) {
    transform: scale(1.04);
    border-color: rgb(var(--text-color) / 0.5);
  }
  .swatch-circle {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 1px solid rgb(var(--text-color) / 0.08);
  }
  .swatch-thumb {
    position: absolute;
    inset: 2px;
    border-radius: 50%;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 0.18s;
    pointer-events: none;
  }
  .pdp-color-swatch:hover .swatch-thumb { opacity: 1; }

  /* ===== Color hint pill (fallback feedback) ===== */
  .pdp-color-hint {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(0, 0, 0, 0.78);
    color: #fff;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px;
    letter-spacing: 0.04em;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
    z-index: 5;
    white-space: nowrap;
  }
  .pdp-color-hint.visible { opacity: 1; }

  /* ===== Stock indicator ===== */
  .pdp-stock {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: var(--text-sm);
    color: rgb(var(--text-color) / 0.7);
    margin-bottom: 0.85rem;
  }
  .pdp-stock-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #2ea043;
    flex-shrink: 0;
  }
  .pdp-stock strong {
    color: rgb(var(--text-color));
    font-weight: 700;
  }

  /* ===== Accordion (4 tabs) ===== */
  .product-accordion {
    border-top: 1px solid rgb(var(--border-color) / 0.15);
    margin-top: 1.25rem;
  }
  .product-accordion .accordion-item {
    border-bottom: 1px solid rgb(var(--border-color) / 0.15);
    padding: 1rem 0;
