---
import Layout from '../layouts/Layout.astro';
const base = (import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/');
---
<Layout title="Product — Over2You">
  <div class="pd-page" style="padding:6rem var(--container-gutter) 4rem;max-width:1400px;margin:0 auto;">
    <div class="product-layout" id="productLayout">
      <p style="text-align:center;padding:4rem;color:rgb(var(--text-color)/0.4);">Loading product...</p>
    </div>
  </div>

  <script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const MAX_WAIT_MS = 4000;
    const POLL_MS = 80;
    const started = Date.now();

    const tryRender = () => {
      if (!window.productsReady) {
        if (Date.now() - started > MAX_WAIT_MS) { render(); return; }
        setTimeout(tryRender, POLL_MS);
        return;
      }
      render();
    };

    function attrJSON(obj) {
      return JSON.stringify(obj)
        .replace(/&/g, '&amp;')
        .replace(/'/g, '&#39;');
    }

    function render() {
      const params = new URLSearchParams(window.location.search);
      const id = parseInt(params.get('id'));
      const list = (window.products && window.products.length) ? window.products : [];
      const product = list.find(p => p.id === id);
      const layout = document.getElementById('productLayout');

      if (!product) {
        layout.innerHTML = '<div style="text-align:center;padding:4rem;"><h2 style="font:var(--heading-font-style) 800 1.5rem/1.2 var(--heading-font-family);margin-bottom:1rem;">Product Not Found</h2><a href="' + window.O2Y_BASE + 'shop" class="btn-primary" style="display:inline-block;padding:0.75rem 2rem;">BACK TO SHOP</a></div>';
        return;
      }

      document.title = product.name + ' — Over2You';
      const B = window.O2Y_BASE;
      const imgBase = B + 'img/';
      const related = list.filter(r => r.category === product.category && r.id !== product.id).slice(0, 8);

      const frames360 = Array.isArray(product.images360) ? product.images360 : [];
      const has360 = frames360.length >= 4 && frames360.every(f => f && typeof f === 'object' && f.src);

      const framesData = has360
        ? frames360
        : (Array.isArray(product.images) ? product.images : []);

      const thumbsSource = has360
        ? frames360.map((f, i) => ({ src: f.src, label: f.label || ('View ' + (i+1)), flip: !!f.flip }))
        : (product.images || []).map((src, i) => ({ src, label: 'View ' + (i+1), flip: false }));

      const N = thumbsSource.length;
      const showThumbs = N >= 2;

      const thumbsHTML = showThumbs ? thumbsSource.map((t, i) => `
        <button class="pd-thumb${i === 0 ? ' active' : ''}" type="button" data-idx="${i}" aria-label="${t.label}">
          <img src="${imgBase}${t.src}" alt="${t.label}" style="${t.flip ? 'transform:scaleX(-1);' : ''}">
        </button>
      `).join('') : '';

      const stageHTML =
        `<carousel-3d data-frames='${attrJSON(framesData)}' data-img-base="${imgBase}" data-has-360="${has360}"></carousel-3d>`;

      layout.innerHTML = `
        <div class="product-breadcrumb" style="font-size:11px;color:rgb(var(--text-color)/0.4);margin-bottom:1.5rem;">
          <a href="${B}" style="color:inherit;">Home</a> /
          <a href="${B}shop?cat=${product.category}" style="color:inherit;">${product.category.charAt(0).toUpperCase()+product.category.slice(1)}</a> /
          <span style="color:rgb(var(--text-color)/0.7);">${product.name}</span>
        </div>
        <div class="product-grid-layout">
          <div class="pd-gallery${showThumbs ? '' : ' pd-gallery-no-thumbs'}">
            ${showThumbs ? `<div class="pd-thumbs" id="pdThumbs">${thumbsHTML}</div>` : ''}
            <div class="pd-stage-wrap">${stageHTML}</div>
          </div>
          <div class="pd-info">
            <h1 style="font:var(--heading-font-style) 800 1.5rem/1.2 var(--heading-font-family);text-transform:uppercase;letter-spacing:0.03em;margin-bottom:0.75rem;">${product.name}</h1>
            <p style="font-size:var(--text-base);margin-bottom:1rem;">€${product.price.toFixed(2)}</p>
            ${product.badge ? `<span style="display:inline-block;padding:3px 8px;font-size:10px;font-weight:700;background:rgb(var(--text-color));color:rgb(var(--background));margin-bottom:1.25rem;">${product.badge}</span>` : ''}

            <div style="margin-bottom:1.25rem;">
              <span style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:rgb(var(--text-color)/0.5);display:block;margin-bottom:0.5rem;">COLOR: ${product.colorName}</span>
              <div style="display:flex;gap:6px;flex-wrap:wrap;">
                ${related.map(r => `<a href="${B}product?id=${r.id}" class="swatch-product" style="width:28px;height:28px;border-radius:50%;background:${r.color};border:2px solid transparent;display:block;" title="${r.colorName}"></a>`).join('')}
                <a href="${B}product?id=${product.id}" class="swatch-product selected" style="width:28px;height:28px;border-radius:50%;background:${product.color};border:2px solid rgb(var(--text-color));display:block;" title="${product.colorName}"></a>
              </div>
            </div>

            <div style="margin-bottom:1.25rem;" id="sizeSection">
              <span style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:rgb(var(--text-color)/0.5);display:block;margin-bottom:0.5rem;">SIZE:</span>
              <div style="display:flex;gap:6px;flex-wrap:wrap;" id="sizeButtons">
                ${product.sizes.map(s => `<button class="size-btn" data-size="${s}" style="padding:0.5rem 1rem;border:1px solid rgb(var(--border-color));background:transparent;font:var(--heading-font-style) 600 11px/1 var(--heading-font-family);cursor:pointer;transition:all 0.2s;">${s}</button>`).join('')}
              </div>
            </div>

            <button id="addToCartBtn" style="width:100%;padding:1rem;background:rgb(var(--button-background));color:rgb(var(--button-text-color));border:none;font:var(--heading-font-style) 800 var(--text-sm)/1.65 var(--heading-font-family);text-transform:uppercase;letter-spacing:0.03em;cursor:pointer;transition:all 0.3s;margin-bottom:1.5rem;">ADD TO CART</button>

            <div class="product-accordion" style="border-top:1px solid rgb(var(--border-color)/0.15);">
              <div class="accordion-item" onclick="this.classList.toggle('open');this.nextElementSibling.style.display=this.nextElementSibling.style.display==='block'?'none':'block';" style="border-bottom:1px solid rgb(var(--border-color)/0.15);padding:1rem 0;cursor:pointer;display:flex;justify-content:space-between;align-items:center;"><span style="font:var(--heading-font-style) 600 13px/1 var(--heading-font-family);text-transform:uppercase;">Product Details</span><span>+</span></div>
              <div style="display:none;padding:0 0 1rem;font-size:var(--text-sm);color:rgb(var(--text-color)/0.6);line-height:1.7;">${product.description}</div>
              <div class="accordion-item" onclick="this.classList.toggle('open');this.nextElementSibling.style.display=this.nextElementSibling.style.display==='block'?'none':'block';" style="border-bottom:1px solid rgb(var(--border-color)/0.15);padding:1rem 0;cursor:pointer;display:flex;justify-content:space-between;align-items:center;"><span style="font:var(--heading-font-style) 600 13px/1 var(--heading-font-family);text-transform:uppercase;">Shipping & Returns</span><span>+</span></div>
              <div style="display:none;padding:0 0 1rem;font-size:var(--text-sm);color:rgb(var(--text-color)/0.6);line-height:1.7;">Free shipping on orders over €100. Standard delivery 3-5 business days. Free returns within 30 days.</div>
            </div>
          </div>
        </div>
      `;

      wireInteractions(product);
    }

    function wireInteractions(product) {
      const logoEls = document.querySelectorAll('.header .logo-text');
      logoEls.forEach(el => el.style.color = product.color);
      document.querySelectorAll('.swatch-product').forEach(swatch => {
        swatch.addEventListener('mouseenter', () => {
          const c = swatch.style.background || swatch.style.backgroundColor;
          logoEls.forEach(el => el.style.color = c);
        });
        swatch.addEventListener('mouseleave', () => logoEls.forEach(el => el.style.color = product.color));
      });

      const carousel = document.querySelector('carousel-3d');
      const thumbs = document.querySelectorAll('.pd-thumb');

      thumbs.forEach(t => {
        t.addEventListener('click', () => {
          thumbs.forEach(x => x.classList.remove('active'));
          t.classList.add('active');
          const i = parseInt(t.dataset.idx, 10);
          if (carousel && typeof carousel.setIdx === 'function') {
            carousel.setIdx(i);
            carousel.setMode('flat');
          }
        });
      });

      if (carousel) {
        carousel.addEventListener('c3d:idx-change', (e) => {
          const i = e.detail && e.detail.idx;
          if (typeof i !== 'number') return;
          thumbs.forEach((t, n) => t.classList.toggle('active', n === i));
        });
      }

      let selectedSize = null;
      document.querySelectorAll('.size-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.size-btn').forEach(b => { b.style.background = 'transparent'; b.style.color = 'inherit'; });
          btn.style.background = 'rgb(var(--button-background))';
          btn.style.color = 'rgb(var(--button-text-color))';
          selectedSize = btn.dataset.size;
        });
      });

      const addToCart = document.getElementById('addToCartBtn');
      if (addToCart) addToCart.addEventListener('click', () => {
        if (!selectedSize) {
          const section = document.getElementById('sizeSection');
          section.style.outline = '2px solid #c94c4c';
          section.style.outlineOffset = '4px';
          setTimeout(() => { section.style.outline = 'none'; }, 1500);
          return;
        }
        if (window.Cart && typeof window.Cart.add === 'function') window.Cart.add(product, selectedSize);
        const btn = document.getElementById('addToCartBtn');
        btn.textContent = '✓ ADDED'; btn.style.background = '#28a745';
        setTimeout(() => { btn.textContent = 'ADD TO CART'; btn.style.background = 'rgb(var(--button-background))'; }, 2000);
      });
    }

    tryRender();
  });
  </script>
</Layout>

<style is:global>
  /* ===== Product page layout =====
     Outer wrapper renamed .pd-page to escape legacy `.product-container { display:grid; 1.2fr 0.8fr }`
     in style.css that hijacked our layout. .pd-gallery / .pd-info renamed for the same reason. */
  .pd-page {
    display: block;
  }
  .product-grid-layout {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: 3rem;
    align-items: start;
  }
  .pd-gallery {
    display: grid;
    grid-template-columns: 80px minmax(0, 1fr);
    gap: 1rem;
    position: sticky;
    top: 6rem;
  }
  .pd-gallery-no-thumbs {
    grid-template-columns: minmax(0, 1fr);
  }
  .pd-info {
    position: static;
  }

  /* ===== Thumbnail rail ===== */
  .pd-thumbs {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .pd-thumb {
    position: relative;
    width: 80px;
    aspect-ratio: 3 / 4;
    padding: 0;
    border: 1px solid rgb(var(--border-color) / 0.15);
    background: rgb(var(--background));
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.15s, transform 0.15s;
  }
  .pd-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .pd-thumb.active { border-color: rgb(var(--text-color)); }
  .pd-thumb:hover { transform: translateY(-1px); }

  /* ===== Stage wrapper + flat fallback ===== */
  .pd-stage-wrap {
    position: relative;
    width: 100%;
  }
  .pd-flat-fallback {
    width: 100%;
    aspect-ratio: 3 / 4;
    background: rgb(var(--background));
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .pd-flat-fallback img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  /* ===== <carousel-3d> custom element ===== */
  carousel-3d {
    display: block;
    width: 100%;
  }
  .c3d-stage {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    min-height: 480px;
    max-height: 80vh;
    background:
      radial-gradient(ellipse 60% 40% at 50% 80%, rgba(0,0,0,0.06), transparent 70%),
      rgb(var(--background));
    overflow: hidden;
  }
  .c3d-stage-empty {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .c3d-empty-msg {
    text-align: center;
    color: rgb(var(--text-color) / 0.35);
  }
  .c3d-empty-msg svg {
    margin: 0 auto 0.75rem;
    display: block;
  }
  .c3d-empty-msg p {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .c3d-flat,
  .c3d-360 {
    position: absolute;
    inset: 0;
  }
  .c3d-flat {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .c3d-flat[hidden],
  .c3d-360[hidden] { display: none; }
  .c3d-flat img {
    max-width: 95%;
    max-height: 95%;
    width: auto;
    height: auto;
    object-fit: contain;
    object-position: center bottom;
    user-select: none;
    -webkit-user-drag: none;
  }

  /* Toggle (top-right) */
  .c3d-toggle {
    position: absolute;
    top: 18px;
    right: 18px;
    width: 54px;
    height: 54px;
    z-index: 6;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgb(var(--text-color));
    background: rgb(var(--background));
    color: rgb(var(--text-color));
    cursor: pointer;
    padding: 0;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .c3d-toggle:hover {
    background: rgb(var(--text-color));
    color: rgb(var(--background));
  }
  .c3d-toggle .c3d-lbl {
    font: 600 9px/1 var(--heading-font-family);
    letter-spacing: 0.1em;
    text-align: center;
    display: block;
  }
  .c3d-toggle .c3d-lbl b {
    display: block;
    font-weight: 800;
    font-size: 11px;
    margin-top: 2px;
  }

  /* Cylinder slots — slot wraps the image; height drives the size,
     width auto-follows from image's natural aspect to avoid any stretching. */
  .c3d-slot {
    position: absolute;
    top: 50%;
    left: 50%;
    height: 88%;
    background: transparent;
    border: 0;
    padding: 0;
    transform-origin: center center;
    transform: translate(-50%, -50%);
    will-change: transform, opacity;
  }
  .c3d-slot img {
    height: 100%;
    width: auto;
    display: block;
    object-fit: contain;
    object-position: center bottom;
    pointer-events: none;
    user-select: none;
    -webkit-user-drag: none;
  }
  .c3d-slot-active { cursor: default; }

  /* Floor anchor */
  .c3d-floor {
    position: absolute;
    left: 50%;
    bottom: 10%;
    width: 70%;
    height: 24px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse at center, rgba(0,0,0,0.10), transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* Arrows */
  .c3d-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 8;
    width: 44px;
    height: 44px;
    border: 1px solid rgb(var(--text-color));
    background: rgb(var(--background) / 0.9);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: rgb(var(--text-color));
    padding: 0;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .c3d-arrow:hover {
    background: rgb(var(--text-color));
    color: rgb(var(--background));
  }
  .c3d-arrow svg { width: 20px; height: 20px; }
  .c3d-arrow-l { left: 12px; }
  .c3d-arrow-r { right: 12px; }

  /* Counter */
  .c3d-counter {
    position: absolute;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    font: 500 10px/1 var(--heading-font-family);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(var(--text-color) / 0.5);
    pointer-events: none;
  }

  /* ===== Mobile breakpoint ===== */
  @media (max-width: 768px) {
    .product-grid-layout {
      grid-template-columns: minmax(0, 1fr);
      gap: 1.5rem;
    }
    .pd-gallery,
    .pd-gallery-no-thumbs {
      grid-template-columns: minmax(0, 1fr);
      position: static;
      gap: 0.75rem;
    }
    .pd-thumbs {
      flex-direction: row;
      order: 2;
      justify-content: center;
      flex-wrap: wrap;
    }
    .pd-thumb { width: 64px; }
    .pd-stage-wrap { order: 1; }
    .c3d-stage { min-height: 380px; }
    .c3d-toggle { width: 48px; height: 48px; top: 12px; right: 12px; }
    .c3d-arrow { width: 38px; height: 38px; }
    .c3d-counter { font-size: 9px; }
  }
</style>
