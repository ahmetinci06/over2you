---
import Layout from '../layouts/Layout.astro';
const base = (import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/');
---
<Layout title="Product — Over2You">
  <div class="product-container" style="padding:6rem var(--container-gutter) 4rem;max-width:1400px;margin:0 auto;">
    <div class="product-layout" id="productLayout">
      <!-- JS renders product here -->
      <p style="text-align:center;padding:4rem;color:rgb(var(--text-color)/0.4);">Loading product...</p>
    </div>
  </div>

  <!-- 360 Viewer Modal -->
  <div class="viewer-360-modal" id="viewer360Modal">
    <button class="viewer-360-close" id="close360Btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="viewer-360-container" id="viewer360Container">
      <img src="" id="viewer360Image" alt="360 View" style="max-height:80vh;width:auto;margin:0 auto;cursor:grab;user-select:none;" draggable="false">
      <div class="viewer-360-instruction">⇆ DRAG TO ROTATE</div>
    </div>
  </div>

  <script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tryRender = () => {
      if (!window.products || window.products.length === 0) { setTimeout(tryRender, 100); return; }

      const params = new URLSearchParams(window.location.search);
      const id = parseInt(params.get('id'));
      const product = window.products.find(p => p.id === id);
      const layout = document.getElementById('productLayout');

      if (!product) {
        layout.innerHTML = '<div style="text-align:center;padding:4rem;"><h2 style="font:var(--heading-font-style) 800 1.5rem/1.2 var(--heading-font-family);margin-bottom:1rem;">Product Not Found</h2><a href="' + window.O2Y_BASE + 'shop" class="btn-primary" style="display:inline-block;padding:0.75rem 2rem;">BACK TO SHOP</a></div>';
        return;
      }

      document.title = product.name + ' — Over2You';

      const B = window.O2Y_BASE;
      const imgBase = B + 'img/';
      const related = window.products.filter(r => r.category === product.category && r.id !== product.id).slice(0, 8);

      layout.innerHTML = `
        <div class="product-breadcrumb" style="font-size:11px;color:rgb(var(--text-color)/0.4);margin-bottom:1.5rem;">
          <a href="${B}" style="color:inherit;">Home</a> /
          <a href="${B}shop?cat=${product.category}" style="color:inherit;">${product.category.charAt(0).toUpperCase()+product.category.slice(1)}</a> /
          <span style="color:rgb(var(--text-color)/0.7);">${product.name}</span>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;" class="product-grid-layout">
          <div class="product-gallery">
            <div class="product-main-images">
              <div style="position:relative;">
                <img src="${imgBase}${product.images[0]}" alt="${product.name}" style="width:100%;">
                <button class="view-360-btn" id="open360Btn" title="360° View">
                  <img src="${imgBase}${product.images[1] || product.images[0]}" alt="360" style="width:100%;height:100%;object-fit:cover;">
                </button>
              </div>
              ${product.images.slice(1).map(img => `<img src="${imgBase}${img}" alt="${product.name}" style="width:100%;">`).join('')}
            </div>
          </div>
          <div class="product-info">
            <h1 style="font:var(--heading-font-style) 800 1.5rem/1.2 var(--heading-font-family);text-transform:uppercase;letter-spacing:0.03em;margin-bottom:0.75rem;">${product.name}</h1>
            <p style="font-size:var(--text-base);margin-bottom:1.5rem;">€${product.price.toFixed(2)}</p>
            ${product.badge ? `<span style="display:inline-block;padding:3px 8px;font-size:10px;font-weight:700;background:rgb(var(--text-color));color:rgb(var(--background));margin-bottom:1rem;">${product.badge}</span>` : ''}
            
            <div style="margin-bottom:1.5rem;">
              <span style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:rgb(var(--text-color)/0.5);display:block;margin-bottom:0.5rem;">COLOR: ${product.colorName}</span>
              <div style="display:flex;gap:6px;flex-wrap:wrap;">
                ${related.map(r => `<a href="${B}product?id=${r.id}" class="swatch-product ${r.id===product.id?'selected':''}" style="width:28px;height:28px;border-radius:50%;background:${r.color};border:2px solid ${r.id===product.id?'rgb(var(--text-color))':'transparent'};display:block;" title="${r.colorName}"></a>`).join('')}
                <a href="${B}product?id=${product.id}" style="width:28px;height:28px;border-radius:50%;background:${product.color};border:2px solid rgb(var(--text-color));display:block;" title="${product.colorName}"></a>
              </div>
            </div>
            
            <div style="margin-bottom:1.5rem;" id="sizeSection">
              <span style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:rgb(var(--text-color)/0.5);display:block;margin-bottom:0.5rem;">SIZE:</span>
              <div style="display:flex;gap:6px;flex-wrap:wrap;" id="sizeButtons">
                ${product.sizes.map(s => `<button class="size-btn" data-size="${s}" style="padding:0.5rem 1rem;border:1px solid rgb(var(--border-color));background:transparent;font:var(--heading-font-style) 600 11px/1 var(--heading-font-family);cursor:pointer;transition:all 0.2s;">${s}</button>`).join('')}
              </div>
            </div>
            
            <button id="addToCartBtn" style="width:100%;padding:1rem;background:rgb(var(--button-background));color:rgb(var(--button-text-color));border:none;font:var(--heading-font-style) 800 var(--text-sm)/1.65 var(--heading-font-family);text-transform:uppercase;letter-spacing:0.03em;cursor:pointer;transition:all 0.3s;margin-bottom:1.5rem;">ADD TO CART</button>
            
            <div class="product-accordion" style="border-top:1px solid rgb(var(--border-color)/0.15);">
              <div class="accordion-item" onclick="this.classList.toggle('open');this.nextElementSibling.style.display=this.nextElementSibling.style.display==='block'?'none':'block';" style="border-bottom:1px solid rgb(var(--border-color)/0.15);padding:1rem 0;cursor:pointer;display:flex;justify-content:space-between;align-items:center;"><span style="font:var(--heading-font-style) 600 13px/1 var(--heading-font-family);text-transform:uppercase;">Product Details</span><span>+</span></div>
              <div style="display:none;padding:0 0 1rem;font-size:var(--text-sm);color:rgb(var(--text-color)/0.6);line-height:1.7;">${product.description}</div>
              <div class="accordion-item" onclick="this.classList.toggle('open');this.nextElementSibling.style.display=this.nextElementSibling.style.display==='block'?'none':'block';" style="border-bottom:1px solid rgb(var(--border-color)/0.15);padding:1rem 0;cursor:pointer;display:flex;justify-content:space-between;align-items:center;"><span style="font:var(--heading-font-style) 600 13px/1 var(--heading-font-family);text-transform:uppercase;">Shipping & Returns</span><span>+</span></div>
              <div style="display:none;padding:0 0 1rem;font-size:var(--text-sm);color:rgb(var(--text-color)/0.6);line-height:1.7;">Free shipping on orders over €100. Standard delivery 3-5 business days. Free returns within 30 days.</div>
            </div>
          </div>
        </div>
      `;

      // Logo color on swatch hover
      const logoEls = document.querySelectorAll('.header .logo-text');
      document.querySelectorAll('.swatch-product').forEach(swatch => {
        swatch.addEventListener('mouseenter', () => {
          const c = swatch.style.background || swatch.style.backgroundColor;
          logoEls.forEach(el => el.style.color = c);
        });
        swatch.addEventListener('mouseleave', () => {
          logoEls.forEach(el => el.style.color = '');
        });
      });

      // Size picker
      let selectedSize = null;
      document.querySelectorAll('.size-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.size-btn').forEach(b => { b.style.background = 'transparent'; b.style.color = 'inherit'; });
          btn.style.background = 'rgb(var(--button-background))';
          btn.style.color = 'rgb(var(--button-text-color))';
          selectedSize = btn.dataset.size;
        });
      });

      // Add to cart
      document.getElementById('addToCartBtn').addEventListener('click', () => {
        if (!selectedSize) {
          const section = document.getElementById('sizeSection');
          section.style.animation = 'none'; section.offsetHeight;
          section.style.outline = '2px solid #c94c4c'; section.style.outlineOffset = '4px';
          setTimeout(() => { section.style.outline = 'none'; }, 1500);
          return;
        }
        Cart.add(product, selectedSize);
        const btn = document.getElementById('addToCartBtn');
        btn.textContent = '✓ ADDED'; btn.style.background = '#28a745';
        setTimeout(() => { btn.textContent = 'ADD TO CART'; btn.style.background = 'rgb(var(--button-background))'; }, 2000);
      });

      // 360 viewer
      const open360 = document.getElementById('open360Btn');
      const modal360 = document.getElementById('viewer360Modal');
      const close360 = document.getElementById('close360Btn');
      const img360 = document.getElementById('viewer360Image');
      if (open360 && modal360) {
        img360.src = imgBase + product.images[0];
        open360.addEventListener('click', () => { modal360.classList.add('active'); document.body.style.overflow = 'hidden'; });
        close360.addEventListener('click', () => { modal360.classList.remove('active'); document.body.style.overflow = ''; });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { modal360.classList.remove('active'); document.body.style.overflow = ''; } });
      }
    };
    tryRender();
  });
  </script>
</Layout>

<style is:inline>
@media (max-width: 768px) {
  .product-grid-layout { grid-template-columns: 1fr !important; }
}
</style>
