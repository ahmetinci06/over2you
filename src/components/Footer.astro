---
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---
<footer class="footer">
  <div class="footer-grid">
    <div class="footer-col">
      <h4>İLETİŞİM</h4>
      <p data-i18n="footer.supportText">SİPARİŞ SORULARI İÇİN BİZE ULAŞIN</p>
      <a href="mailto:SUPPORT@OVER2YOU.COM">SUPPORT@OVER2YOU.COM</a>
      <p data-i18n="footer.weekdays">(PAZARTESİ-CUMA)</p>
    </div>
    <div class="footer-col">
      <h4 data-i18n="footer.service">Hizmet</h4>
      <a href={`${base}iletisim`} data-i18n="footer.support">DESTEK</a>
      <a href={`${base}iade-politikasi`} data-i18n="footer.returns">İade</a>
      <a href={`${base}kargo`} data-i18n="footer.shippingLink">Kargo</a>
    </div>
    <div class="footer-col">
      <h4 data-i18n="footer.legal">Yasal</h4>
      <a href={`${base}kunye`} data-i18n="footer.imprint">Künye</a>
      <a href={`${base}gizlilik-politikasi`} data-i18n="footer.privacy">Gizlilik Politikası</a>
      <a href={`${base}kullanim-kosullari`} data-i18n="footer.terms">Kullanım Koşulları</a>
      <a href={`${base}iade-politikasi`} data-i18n="footer.refund">İade Politikası</a>
      <a href={`${base}mesafeli-satis`}>Mesafeli Satış Sözleşmesi</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© 2026 - Over2You. Tüm hakları saklıdır.</p>
    <p data-i18n="footer.securePayments" style="margin-top:0.4rem;font-size:11px;letter-spacing:0.06em;">GÜVENLİ ÖDEME</p>
  </div>
</footer>
